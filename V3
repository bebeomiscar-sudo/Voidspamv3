    pcall(function()
        local char = lp.Character
        if not char then return end
        local myRoot = char:FindFirstChild("HumanoidRootPart")
        if not myRoot then return end
        local hum     = char:FindFirstChild("Humanoid")
        local needsHp = hum and hum.Health < hum.MaxHealth

        for _, obj in ipairs(Workspace:GetChildren()) do
            if obj.Name ~= "_drop" then continue end
            if not obj:IsA("BasePart") then continue end

            -- radius check
            if (obj.Position - myRoot.Position).Magnitude > Config.AutoCollect.Radius then continue end

            local hasHealth = obj:FindFirstChild("Health")
            local hasAmmo   = obj:FindFirstChild("Ammo")

            local wantHp   = Config.AutoCollect.CollectHealth and hasHealth
            local wantAmmo = Config.AutoCollect.CollectAmmo   and hasAmmo

            -- if OnlyNeeded is on, only grab health when we actually need it
            if Config.AutoCollect.OnlyNeeded and wantHp and not needsHp then
                wantHp = false
            end

            if wantHp or wantAmmo then
                firetouchinterest(myRoot, obj, 0)
                firetouchinterest(myRoot, obj, 1)
            end
        end
    end)
end)

