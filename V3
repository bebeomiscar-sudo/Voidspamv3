local function isSameTeam(p)
    local same = false
    pcall(function()
        local myID    = LP:GetAttribute("TeamID")
        local theirID = p:GetAttribute("TeamID")
        if myID and theirID then
            same = string.byte(myID or "\0") == string.byte(theirID or "\0")
        end
    end)
    if not same then
        pcall(function()
            same = p.Team ~= nil and LP.Team ~= nil and p.Team == LP.Team
        end)
    end
    return same
end

local function rbGetHRP(player)
    local char = player and player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart")
end

-- Find the closest alive enemy for ragebot targeting
local function rbGetClosest()
    if not LP.Character then return nil, nil end
    local myHRP = LP.Character:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil, nil end

    local best, bestChar, bestDist = nil, nil, CFG.Ragebot.MaxDistance

    for _, p in next, players_sa:GetPlayers() do
        if p == LP then continue end
        if CFG.Ragebot.TeamCheck and isSameTeam(p) then continue end
        if not p.Character then continue end

        local head = p.Character:FindFirstChild("Head")
        if not head then continue end

        local hum = p.Character:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end

        local mag = (myHRP.Position - head.Position).Magnitude
        if mag < bestDist then
            bestDist  = mag
            best      = head
            bestChar  = p.Character
        end
    end

    return best, bestChar
end

-- Calculate shoot position, accounting for walls
local function rbCalcPoint(origin, targetPos, targetChar)
    ray_params_rb.FilterDescendantsInstances = {LP.Character, targetChar}
    ray_params_rb.FilterType = Enum.RaycastFilterType.Exclude

    if not CFG.Ragebot.VisibleCheck then return origin, nil end

    if not ws_sa:Raycast(origin, targetPos - origin, ray_params_rb) then
        return origin, nil
    end

    for _, offset in next, rb_offsets do
        local scanPos = origin + offset
        if not ws_sa:Raycast(scanPos, targetPos - scanPos, ray_params_rb) then
            return scanPos, offset.Y
        end
    end

    return nil, nil
end

-- ═══════════════════════════════════════════
-- WALL BANG TELEPORT SYSTEM
-- Teleports your HRP inside the target when ragebot fires
-- Restores position after the shot frame
-- ═══════════════════════════════════════════

-- Stop any existing wall bang teleport and restore position
local function stopWallBang()
    if RagebotState.wbConn then
        RagebotState.wbConn:Disconnect()
        RagebotState.wbConn = nil
    end
    RagebotState.wbActive = false

    if CFG.Ragebot.WallBangRestore and RagebotState.wbOrigPos then
        local char = LP.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        pcall(function()
            if hrp then
                hrp.CFrame                   = CFrame.new(RagebotState.wbOrigPos)
                hrp.AssemblyLinearVelocity   = Vector3.zero
                hrp.AssemblyAngularVelocity  = Vector3.zero
            end
        end)
    end

    RagebotState.wbOrigPos = nil
end

-- Teleport into target for one shot frame then restore
-- Called right before each UseItem fire remote
local function wallBangTeleport(targetHRP)
    if not CFG.Ragebot.WallBang then return end
    if not targetHRP then return end

    local char = LP.Character
    local myHRP = char and char:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end

    -- Save current position for restoration
    if not RagebotState.wbActive then
        RagebotState.wbOrigPos = myHRP.Position
    end

    RagebotState.wbActive = true

    -- Teleport into target with slight forward offset
    local targetCF = targetHRP.CFrame * CFrame.new(0, 0, CFG.Ragebot.WallBangOffset)
    pcall(function()
        myHRP.CFrame                   = targetCF
        myHRP.AssemblyLinearVelocity   = Vector3.zero
        myHRP.AssemblyAngularVelocity  = Vector3.zero
    end)

    CFG.Stats.WallBangTeleports = CFG.Stats.WallBangTeleports + 1

    -- Restore next frame so we dont visually stay inside them
    -- Only if void is not active — if void is on, void will reposition us
    if not CFG.Void.On then
        task.defer(function()
            if not CFG.Ragebot.WallBang then return end
            local c   = LP.Character
            local hrp = c and c:FindFirstChild("HumanoidRootPart")
            if hrp and RagebotState.wbOrigPos then
                pcall(function()
                    hrp.CFrame                   = CFrame.new(RagebotState.wbOrigPos)
                    hrp.AssemblyLinearVelocity   = Vector3.zero
                    hrp.AssemblyAngularVelocity  = Vector3.zero
                end)
            end
            RagebotState.wbActive  = false
            RagebotState.wbOrigPos = nil
        end)
    end
end

