local function betterRandom(min, max, deadMin, deadMax)
    local val = math.random(min, max)
    repeat val = math.random(min, max)
    until val < deadMin or val > deadMax
    return val
end

local function IsAlive(player)
    if not player or not player.Character then return false end
    local hum = player.Character:FindFirstChildOfClass("Humanoid")
    return hum and hum.Health > 0
end

local function isSameTeam(player)
    local ok1, myTeam    = pcall(function() return LocalPlayer:GetAttribute("TeamID") end)
    local ok2, theirTeam = pcall(function() return player:GetAttribute("TeamID") end)
    if ok1 and ok2 and myTeam ~= nil and theirTeam ~= nil then return myTeam == theirTeam end
    return LocalPlayer.Team ~= nil and player.Team ~= nil and LocalPlayer.Team == player.Team
end

local function isVisibleFrom(origin, targetPart)
    if not targetPart then return false end
    local ok, r = pcall(function()
        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Exclude
        params.FilterDescendantsInstances = {LocalPlayer.Character, targetPart.Parent}
        local hit = Workspace:Raycast(origin, targetPart.Position - origin, params)
        return hit == nil or hit.Instance:IsDescendantOf(targetPart.Parent)
    end)
    return ok and r or false
end

local function getScreenCenter()
    return Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
end

local function angleDiff(f, t)
    local d = t - f
    return ((d + math.pi) % (math.pi * 2)) - math.pi
end

-- ─── TARGET PART SYSTEM ───────────────────
local ALL_TARGET_PARTS = {
    "Head","HumanoidRootPart","UpperTorso","LowerTorso","Torso",
    "LeftUpperArm","LeftLowerArm","LeftHand","RightUpperArm","RightLowerArm","RightHand",
    "LeftUpperLeg","LeftLowerLeg","LeftFoot","RightUpperLeg","RightLowerLeg","RightFoot",
}
local TARGET_PART_PRESETS = {
    ["Head"]       = {"Head"},
    ["HumanoidRootPart"] = {"HumanoidRootPart"},
    ["Torso"]      = {"Torso","UpperTorso","LowerTorso","HumanoidRootPart"},
    ["UpperTorso"] = {"UpperTorso","Torso","LowerTorso","HumanoidRootPart"},
    ["LowerTorso"] = {"LowerTorso","Torso","UpperTorso","HumanoidRootPart"},
    ["Body"]       = {"UpperTorso","LowerTorso","Torso","HumanoidRootPart"},
    ["Head, Body"] = {"Head","UpperTorso","LowerTorso","Torso","HumanoidRootPart"},
    ["Random"]     = {"Random"},
}
local TARGET_OPTIONS = {
    "Head","HumanoidRootPart","Torso","UpperTorso","LowerTorso",
    "Body","Head, Body","Random"
}

local function getBestPart(char, setting)
    local preset = TARGET_PART_PRESETS[setting] or {"Head"}
    if preset[1] == "Random" then
        local available = {}
        for _, pn in ipairs(ALL_TARGET_PARTS) do
            local p = char:FindFirstChild(pn); if p then table.insert(available, p) end
        end
        return #available > 0 and available[math.random(1, #available)] or nil
    end
    for _, pn in ipairs(preset) do local p = char:FindFirstChild(pn); if p then return p end end
    for _, pn in ipairs(ALL_TARGET_PARTS) do local p = char:FindFirstChild(pn); if p then return p end end
    return nil
end

-- ─── ENEMY SORTING ────────────────────────
local function GetEnemiesSorted()
    local list    = {}
    local myRoot  = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and IsAlive(player) then
            if Config.ProjectileTP.TeamCheck and isSameTeam(player) then continue end
            local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if root and myRoot then
                local dist = (myRoot.Position - root.Position).Magnitude
                if dist <= Config.ProjectileTP.MaxDistance then
                    if Config.ProjectileTP.VisCheck and not isVisibleFrom(myRoot.Position, root) then continue end
                    table.insert(list, {player = player, dist = dist})
                end
            end
        end
    end
    local priority = Config.ProjectileTP.Priority
    if priority == "Closest" then
        table.sort(list, function(a,b) return a.dist < b.dist end)
    elseif priority == "Furthest" then
        table.sort(list, function(a,b) return a.dist > b.dist end)
    elseif priority == "Random" then
        for i = #list, 2, -1 do
            local j = math.random(i); list[i], list[j] = list[j], list[i]
        end
    elseif priority == "Lowest HP" then
        table.sort(list, function(a,b)
            local ha = a.player.Character:FindFirstChildOfClass("Humanoid")
            local hb = b.player.Character:FindFirstChildOfClass("Humanoid")
            return (ha and ha.Health or 0) < (hb and hb.Health or 0)
        end)
    elseif priority == "Highest HP" then
        table.sort(list, function(a,b)
            local ha = a.player.Character:FindFirstChildOfClass("Humanoid")
            local hb = b.player.Character:FindFirstChildOfClass("Humanoid")
            return (ha and ha.Health or 0) > (hb and hb.Health or 0)
        end)
    end
    local result = {}
    for _, e in ipairs(list) do table.insert(result, e.player) end
    return result
end

local function GetClosestEnemy()
    local list = GetEnemiesSorted()
    return list[1]
end

local function CacheEnemies()
    EnemyCache = GetEnemiesSorted()
end

-- ═══════════════════════════════════════════
-- AIMBOT SYSTEM
-- Uses CameraController:SetRotation for smooth
-- camera-based aim — same as rivals legitbot
-- ═══════════════════════════════════════════

local function getAimbotEffectiveFOV()
    local f = Config.Aimbot.MaxFOV
    if Config.Aimbot.DynamicFOV then f = f * (camera.FieldOfView / 70) end
    return f
end

local function isInAimbotFOV(targetPart)
    if not targetPart then return false end
    local sp, onScreen = camera:WorldToViewportPoint(targetPart.Position)
    if not onScreen then return false end
    return (Vector2.new(sp.X, sp.Y) - getScreenCenter()).Magnitude <= getAimbotEffectiveFOV()
end

local function resetDelayedPos() delayedTargetPos = nil end

local function getDelayedPos(targetPart, dt)
    if not targetPart or not targetPart.Parent then delayedTargetPos = nil; return nil end
    local realPos = targetPart.Position
    if not delayedTargetPos then delayedTargetPos = realPos; return realPos end
    local isJumping = false
    pcall(function()
        local hrpT = targetPart.Parent:FindFirstChild("HumanoidRootPart")
        if hrpT then isJumping = hrpT.AssemblyLinearVelocity.Y > 2 end
    end)
    local bf = 60 * dt
    local xA = math.clamp((1 - Config.Aimbot.XSmooth) * (1 + bf), 0.01, 1)
    local yA = (isJumping and Config.Aimbot.JumpSmooth > 0)
        and math.clamp((1 - Config.Aimbot.JumpSmooth) * (1 + bf), 0.01, 1)
        or  math.clamp((1 - Config.Aimbot.YSmooth)    * (1 + bf), 0.01, 1)
    delayedTargetPos = Vector3.new(
        delayedTargetPos.X + (realPos.X - delayedTargetPos.X) * xA,
        delayedTargetPos.Y + (realPos.Y - delayedTargetPos.Y) * yA,
        delayedTargetPos.Z + (realPos.Z - delayedTargetPos.Z) * xA
    )
    return delayedTargetPos
end

local function isAimbotTargetStillValid(part)
    if not part or not part.Parent then return false end
    local hum = part.Parent:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if not isInAimbotFOV(part) then return false end
    if Config.Aimbot.VisibleCheck and not isVisibleFrom(camera.CFrame.Position, part) then return false end
    if Config.Aimbot.TeamCheck then
        local p = Players:GetPlayerFromCharacter(part.Parent)
        if p and isSameTeam(p) then return false end
    end
    return true
end

local function findNewAimbotTarget()
    local c = getScreenCenter(); local eFOV = getAimbotEffectiveFOV(); local bp, bd = nil, eFOV
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        if Config.Aimbot.TeamCheck and isSameTeam(p) then continue end
        local ch = p.Character; if not ch then continue end
        local h = ch:FindFirstChildOfClass("Humanoid"); if not h or h.Health <= 0 then continue end
        local part = getBestPart(ch, Config.Aimbot.TargetPart); if not part then continue end
        local sp, on = camera:WorldToScreenPoint(part.Position); if not on then continue end
        local d = (Vector2.new(sp.X, sp.Y) - c).Magnitude; if d > eFOV then continue end
        if Config.Aimbot.VisibleCheck and not isVisibleFrom(camera.CFrame.Position, part) then continue end
        if d < bd then bd = d; bp = part end
    end
    return bp
end

-- ═══════════════════════════════════════════
-- TRACK DUMMY SYSTEM
-- Locks aimbot onto a shooting range dummy
-- Dummies: workspace.ShootingRangeEntities children
-- Index 99 = first dummy option
-- Index 40 = second dummy option
-- ═══════════════════════════════════════════

local function getDummyTarget()
    local entities = Workspace:FindFirstChild("ShootingRangeEntities")
    if not entities then return nil end
    local children = entities:GetChildren()
    local idx      = Config.TrackDummy.DummyIndex

    -- Clamp to valid range
    idx = math.clamp(idx, 1, #children)
    local dummy = children[idx]
    if not dummy then return nil end

    -- Try to get a targetable part from the dummy
    local part = dummy:FindFirstChild("Head")
        or dummy:FindFirstChild("HumanoidRootPart")
        or dummy:FindFirstChild("UpperTorso")
        or dummy:FindFirstChildOfClass("BasePart")

    return part
end

local function getDummyBestPart()
    local entities = Workspace:FindFirstChild("ShootingRangeEntities")
    if not entities then return nil end
    local children = entities:GetChildren()
    local idx      = math.clamp(Config.TrackDummy.DummyIndex, 1, #children)
    local dummy    = children[idx]
    if not dummy then return nil end
    return getBestPart(dummy, Config.Aimbot.TargetPart)
        or dummy:FindFirstChild("HumanoidRootPart")
        or dummy:FindFirstChildOfClass("BasePart")
end

-- ═══════════════════════════════════════════
-- AIMBOT RENDER LOOP (called in RenderStepped)
-- ═══════════════════════════════════════════
local function runAimbot(dt)
    if not Config.Aimbot.Enabled and not Config.TrackDummy.Enabled then return end

    -- Update FOV circle
    if fovCircle then
        fovCircle.Position = getScreenCenter()
        fovCircle.Radius   = getAimbotEffectiveFOV()
        fovCircle.Visible  = Config.Aimbot.FOVStyle ~= "Invisible"
            and Config.Aimbot.DrawFOV
            and (Config.Aimbot.Enabled or Config.TrackDummy.Enabled)
    end

    if not CameraController then return end

    -- ─── Track Dummy Override ─────────────
    if Config.TrackDummy.Enabled then
        local dummyPart = getDummyBestPart()
        if dummyPart and dummyPart.Parent then
            local aimPos = dummyPart.Position
            pcall(function()
                local cp  = camera.CFrame.Position
                local du  = (aimPos - cp).Unit
                local tP  = math.asin(math.clamp(du.Y, -1, 1))
                local tY  = math.atan2(-du.X, -du.Z)
                local sm  = math.clamp(1 / math.max(Config.Aimbot.Smoothness, 0.1), 0.01, 1)
                local cur = CameraController.Rotation
                CameraController:SetRotation(Vector2.new(
                    cur.X + (tP - cur.X) * sm,
                    cur.Y + angleDiff(cur.Y, tY) * sm
                ))
            end)
        end
        return  -- TrackDummy overrides normal aimbot
    end

    -- ─── Normal Aimbot ────────────────────
    if not Config.Aimbot.Enabled then return end

    if isInReaction then
        reactionTimer = reactionTimer - dt
        if reactionTimer <= 0 then isInReaction = false end
    end

    if not isInReaction then
        if lockedTarget and not isAimbotTargetStillValid(lockedTarget) then
            lockedTarget = nil; lockTimer = 0; resetDelayedPos()
        end
        if not lockedTarget then
            local newT = findNewAimbotTarget()
            if newT then
                lockedTarget  = newT
                lockTimer     = 0
                isInReaction  = true
                reactionTimer = Config.Aimbot.ReactionTime / 1000
                resetDelayedPos()
            end
        end
        if lockedTarget then
            lockTimer = lockTimer + dt
            if lockTimer > Config.Aimbot.ForgotTime then
                lockedTarget = nil; lockTimer = 0; resetDelayedPos()
            else
                if isInAimbotFOV(lockedTarget) then
                    local aimPos = getDelayedPos(lockedTarget, dt)
                    if aimPos then
                        local sm = math.clamp(1 / math.max(Config.Aimbot.Smoothness, 0.1), 0.01, 1)
                        pcall(function()
                            local cp  = camera.CFrame.Position
                            local du  = (aimPos - cp).Unit
                            local tP  = math.asin(math.clamp(du.Y, -1, 1))
                            local tY  = math.atan2(-du.X, -du.Z)
                            local cur = CameraController.Rotation
                            CameraController:SetRotation(Vector2.new(
                                cur.X + (tP - cur.X) * sm,
                                cur.Y + angleDiff(cur.Y, tY) * sm
                            ))
                        end)
                    end
                else
                    lockedTarget = nil; lockTimer = 0; resetDelayedPos()
                end
            end
        end
    end
end

-- ═══════════════════════════════════════════
-- SOUND SPAM SYSTEM
-- Uses Sound IDs from Gun module and AR viewmodel
-- Creates a temporary Sound in workspace and plays it
-- ═══════════════════════════════════════════
local function playSoundOnce(soundId, volume)
    pcall(function()
        local part = Instance.new("Part")
        part.Anchored     = true
        part.CanCollide   = false
        part.Transparency = 1
        part.Size         = Vector3.new(1,1,1)
        local myChar = LocalPlayer.Character
        if myChar then
            local root = myChar:FindFirstChild("HumanoidRootPart")
            part.Position = root and root.Position or Vector3.new(0,0,0)
        end
        part.Parent = Workspace

        local snd = Instance.new("Sound")
        snd.SoundId  = soundId
        snd.Volume   = volume or 1
        snd.RollOffMaxDistance = 10000
        snd.Parent   = part
        snd:Play()

        task.delay(5, function()
            pcall(function() part:Destroy() end)
        end)
    end)
end

local function startSoundSpam()
    if soundSpamTask then task.cancel(soundSpamTask); soundSpamTask = nil end
    soundSpamTask = task.spawn(function()
        while Config.SoundSpam.Enabled do
            local id = (Config.SoundSpam.CustomId ~= "" and Config.SoundSpam.CustomId) or Config.SoundSpam.SoundId
            playSoundOnce(id, Config.SoundSpam.Volume)
            task.wait(math.max(0.01, Config.SoundSpam.Interval))
        end
        soundSpamTask = nil
    end)
end

