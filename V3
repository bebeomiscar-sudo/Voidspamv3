-- util

local function randomExclude(min, max, dMin, dMax)
    -- make sure the dead zone doesnt eat the entire range or we loop forever
    if dMin <= min and dMax >= max then return min end
    local v
    local tries = 0
    repeat
        v = math.random(min, max)
        tries += 1
        if tries > 500 then break end
    until v < dMin or v > dMax
    return v
end

local function isAlive(player)
    if not player or not player.Character then return false end
    local hum = player.Character:FindFirstChildOfClass("Humanoid")
    return hum and hum.Health > 0
end

local function sameTeam(player)
    local myT    = pcall(function() return lp:GetAttribute("TeamID") end)
    local theirT = pcall(function() return player:GetAttribute("TeamID") end)
    if myT and theirT then
        return lp:GetAttribute("TeamID") == player:GetAttribute("TeamID")
    end
    return lp.Team ~= nil and player.Team ~= nil and lp.Team == player.Team
end

local function visibleFrom(origin, part)
    if not part then return false end
    local ok, r = pcall(function()
        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Exclude
        params.FilterDescendantsInstances = { lp.Character, part.Parent }
        local hit = Workspace:Raycast(origin, part.Position - origin, params)
        return hit == nil or hit.Instance:IsDescendantOf(part.Parent)
    end)
    return ok and r or false
end

local function screenCenter()
    return Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
end

local function angleDiff(f, t)
    local d = t - f
    return ((d + math.pi) % (math.pi * 2)) - math.pi
end

