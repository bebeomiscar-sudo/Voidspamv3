    Func = function()
        for _, conn in pairs(Connections) do
            if typeof(conn) == "RBXScriptConnection" then conn:Disconnect() end
        end
        for _, conn in ipairs(antiOOBConnections) do pcall(function() conn:Disconnect() end) end
        for _, conn in ipairs(tracerConnections) do pcall(function() conn:Disconnect() end) end
        for _, conn in ipairs(explosionDeathConnections) do pcall(function() conn:Disconnect() end) end
        for _, conn in ipairs(wtConnections) do pcall(function() conn:Disconnect() end) end
        for _, conn in ipairs(antiProjConnections) do pcall(function() conn:Disconnect() end) end
        for _, player in ipairs(Players:GetPlayers()) do wtUnhookPlayer(player) end
        for _, conns in pairs(omegaMeleeConnections) do
            for _, c in ipairs(conns) do pcall(function() c:Disconnect() end) end
        end
        if ragebotPersistConn then ragebotPersistConn:Disconnect() end
        if omegaPersistConn   then omegaPersistConn:Disconnect() end
        pcall(function() RunService:UnbindFromRenderStep("VoidRestore") end)
        pcall(function() RunService:UnbindFromRenderStep("PureDesyncRestore") end)
        stopRakNet(); stopWeaponTracker(); stopAntiOOB()
        stopLoopExplosions(); stopTracers(); stopAnimation()
        stopPulseDesync(); stopRagebotLoop(); stopSoundSpam()
        disableOmegaBot()
        Config.Weapons.ReloadSpeedEnabled = false; applyReloadPatch()
        if fovCircle then fovCircle:Remove() end
        restorePos(); Library:Unload()
    end,
})

ThemeManager:SetLibrary(Library)
SaveManager:SetLibrary(Library)
