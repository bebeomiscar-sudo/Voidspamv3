-- omegabot melee detection

local function omegaHookMelee(player)
    if player == lp then return end
    omegaMeleeConnections[player] = omegaMeleeConnections[player] or {}

    local function hookTool(tool)
        local conn = tool.Activated:Connect(function()
            if not Config.OmegaBot.Enabled then return end
            if not Config.OmegaBot.StrikeOnMelee then return end
            if Config.OmegaBot.TeamCheck and sameTeam(player) then return end

            task.spawn(function()
                local deadline = tick() + Config.OmegaBot.MeleeWindow
                while tick() < deadline and Config.OmegaBot.Enabled do
                    local proj = omegaFindProjectile()
                    if proj then omegaFireOnEnemy(player, proj) end
                    task.wait(0.02)
                end
            end)
        end)
        table.insert(omegaMeleeConnections[player], conn)
    end

    local function watchChar(char)
        for _, child in ipairs(char:GetChildren()) do
            if child:IsA("Tool") then task.spawn(hookTool, child) end
        end
        local c = char.ChildAdded:Connect(function(child)
            if child:IsA("Tool") then task.spawn(hookTool, child) end
        end)
        table.insert(omegaMeleeConnections[player], c)
    end

    if player.Character then task.spawn(watchChar, player.Character) end

    local c = player.CharacterAdded:Connect(function(char)
        for _, conn in ipairs(omegaMeleeConnections[player] or {}) do
            pcall(function() conn:Disconnect() end)
        end
        omegaMeleeConnections[player] = {}
        task.spawn(watchChar, char)
    end)
    table.insert(omegaMeleeConnections[player], c)
end

local function startOmegaMeleeHooks()
    for _, p in ipairs(Players:GetPlayers()) do task.spawn(omegaHookMelee, p) end
    Players.PlayerAdded:Connect(function(p)
        if Config.OmegaBot.Enabled then omegaHookMelee(p) end
    end)
end

local function setupOmegaPersist()
    if omegaPersistConn then omegaPersistConn:Disconnect() end
    omegaPersistConn = lp.CharacterAdded:Connect(function(char)
        if not omegaWasEnabled then return end
        char:WaitForChild("HumanoidRootPart", 10)
        task.wait(1.5)
        if not Config.OmegaBot.Enabled then
            Config.OmegaBot.Enabled = true
            startOmegaBot()
            Library:Notify("OmegaBot resumed after round", 3)
        end
    end)
end

local function enableOmegaBot()
    Config.OmegaBot.Enabled = true
    omegaWasEnabled         = true
    startOmegaBot()
    startOmegaMeleeHooks()
    setupOmegaPersist()
    Library:Notify(
        "OmegaBot on — hide:" .. math.floor(Config.OmegaBot.HideTime * 1000) ..
        "ms attack:" .. math.floor(Config.OmegaBot.AttackTime * 1000) .. "ms", 4
    )
end

local function disableOmegaBot()
    omegaWasEnabled = false
    stopOmegaBot()
    for _, conns in pairs(omegaMeleeConnections) do
        for _, conn in ipairs(conns) do pcall(function() conn:Disconnect() end) end
    end
    omegaMeleeConnections = {}
end

-- omegabot anti projectile

local function omegaDeflect(proj)
    pcall(function()
        proj.CFrame = CFrame.new(
            math.random(-1000, 1000),
            Config.OmegaBot.AntiProjAltitude,
            math.random(-1000, 1000)
        )
        proj.AssemblyLinearVelocity  = Vector3.zero
        proj.AssemblyAngularVelocity = Vector3.zero
        omegaDeflectCount += 1
    end)
end

local function isEnemyProj(proj)
    local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return false end

    local ok, projPos = pcall(function() return proj.Position end)
    if not ok then return false end

    for _, player in ipairs(Players:GetPlayers()) do
        if player == lp then continue end
        if Config.OmegaBot.TeamCheck and sameTeam(player) then continue end
        local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if root and (projPos - root.Position).Magnitude < 35 then
            return true
        end
    end
    return false
end

local function startAntiProjectile()
    for _, c in ipairs(antiProjConnections) do pcall(function() c:Disconnect() end) end
    antiProjConnections = {}

    local conn = Workspace.ChildAdded:Connect(function(obj)
        if not Config.OmegaBot.AntiProjectile then return end
        if obj.Name ~= "CoreProjectile" then return end

        task.defer(function()
            local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if not myRoot then return end

            pcall(function()
                local frames = 0
                local checkConn
                checkConn = RunService.Heartbeat:Connect(function()
                    frames += 1
                    if frames > 120 then checkConn:Disconnect(); return end
                    if not obj or not obj.Parent then checkConn:Disconnect(); return end

                    local ok, projPos = pcall(function() return obj.Position end)
                    if not ok then checkConn:Disconnect(); return end

                    if (projPos - myRoot.Position).Magnitude < Config.OmegaBot.AntiProjRadius then
                        if isEnemyProj(obj) then
                            omegaDeflect(obj)
                            checkConn:Disconnect()
                        end
                    end
                end)
            end)
        end)
    end)

    table.insert(antiProjConnections, conn)
end

