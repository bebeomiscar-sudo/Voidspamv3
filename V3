-- ragebot

local function startRagebotLoop()
    if ragebotLoopTask then task.cancel(ragebotLoopTask); ragebotLoopTask = nil end
    ragebotLoopTask = task.spawn(function()
        while Config.Ragebot.Enabled do
            local enemies = getEnemiesSorted()
            local enemy   = enemies[1]
            local myRoot  = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")

            if enemy and enemy.Character and myRoot then
                local enemyRoot = enemy.Character:FindFirstChild("HumanoidRootPart")
                if enemyRoot then
                    if Config.Ragebot.VoidSpamSync then
                        ragebotPhase = "hide"
                        if Config.Ragebot.ClientTP then
                            local t = tick() * Config.Ragebot.OrbitSpeed
                            local r = Config.Ragebot.OrbitRadius
                            enemyRoot.CFrame = CFrame.new(
                                myRoot.Position + Vector3.new(math.sin(t) * r, 0, math.cos(t) * r)
                            )
                        end
                        task.wait(Config.Ragebot.HideTime)
                        ragebotPhase = "attack"
                        task.wait(Config.Ragebot.AttackTime)
                    else
                        ragebotPhase = "attack"
                        if Config.Ragebot.ClientTP then
                            local t = tick() * Config.Ragebot.OrbitSpeed
                            local r = Config.Ragebot.OrbitRadius
                            enemyRoot.CFrame = CFrame.new(
                                myRoot.Position + Vector3.new(math.sin(t) * r, 0, math.cos(t) * r)
                            )
                        end
                        task.wait(0.05)
                    end
                end
            else
                ragebotPhase = "attack"
                task.wait(0.1)
            end

            if not Config.Ragebot.Enabled then break end
        end
        ragebotLoopTask = nil
        ragebotPhase    = "attack"
    end)
end

local function stopRagebotLoop()
    if ragebotLoopTask then task.cancel(ragebotLoopTask); ragebotLoopTask = nil end
    ragebotPhase = "attack"
end

local function setupRagebotPersist()
    if ragebotPersistConn then ragebotPersistConn:Disconnect() end
    ragebotPersistConn = lp.CharacterAdded:Connect(function(char)
        if not Config.Ragebot.PersistAcrossRounds or not ragebotWasEnabled then return end
        char:WaitForChild("HumanoidRootPart", 10)
        task.wait(1.5)
        if not Config.Ragebot.Enabled then
            Config.Ragebot.Enabled = true
            startRagebotLoop()
            Library:Notify("Ragebot resumed after round", 3)
        end
    end)
end

local function enableRagebot()
    Config.Ragebot.Enabled = true
    ragebotWasEnabled      = true
    startRagebotLoop()
    setupRagebotPersist()
end

local function disableRagebot()
    Config.Ragebot.Enabled = false
    ragebotWasEnabled      = false
    stopRagebotLoop()
end

