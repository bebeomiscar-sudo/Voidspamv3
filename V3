-- EXPLOSION EFFECTS
-- ═══════════════════════════════════════════
local function triggerExplosion(position, size, pitchVariance)
    if not ExplosionEffectFn then return end
    pcall(function()
        ExplosionEffectFn(
            position or Vector3.new(0,0,0),
            size or Config.ExplosionEffect.Size,
            pitchVariance or (0.9 + Config.ExplosionEffect.SpeedVariance * math.random())
        )
    end)
end

local function hookPlayerForExplosion(player)
    if player == LocalPlayer then return end
    local function watchChar(char)
        local hum = char:WaitForChild("Humanoid", 5)
        if not hum then return end
        local conn = hum.Died:Connect(function()
            if not Config.ExplosionEffect.Enabled then return end
            if not Config.ExplosionEffect.OnDeath then return end
            local root = char:FindFirstChild("HumanoidRootPart")
            if root then triggerExplosion(root.Position, Config.ExplosionEffect.Size) end
        end)
        table.insert(explosionDeathConnections, conn)
    end
    if player.Character then task.spawn(watchChar, player.Character) end
    local conn = player.CharacterAdded:Connect(function(char) task.spawn(watchChar, char) end)
    table.insert(explosionDeathConnections, conn)
end

for _, p in ipairs(Players:GetPlayers()) do hookPlayerForExplosion(p) end
Players.PlayerAdded:Connect(hookPlayerForExplosion)

local function startLoopExplosions()
    if loopExplosionTask then return end
    loopExplosionTask = task.spawn(function()
        while Config.ExplosionEffect.Enabled and Config.ExplosionEffect.LoopExplosions do
            pcall(function()
                local char = LocalPlayer.Character
                if char then
                    local root = char:FindFirstChild("HumanoidRootPart")
                    if root then
                        triggerExplosion(root.Position + Vector3.new(math.random(-5,5),math.random(0,3),math.random(-5,5)), Config.ExplosionEffect.Size * 0.5)
                    end
                end
            end)
            task.wait(Config.ExplosionEffect.LoopInterval)
        end
        loopExplosionTask = nil
    end)
end

local function stopLoopExplosions()
    if loopExplosionTask then task.cancel(loopExplosionTask); loopExplosionTask = nil end
end

local function explodeAtSelf()
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if root then triggerExplosion(root.Position, Config.ExplosionEffect.Size) end
end

local function explodeAtEnemy()
    local enemy = GetClosestEnemy()
    if enemy and enemy.Character then
        local root = enemy.Character:FindFirstChild("HumanoidRootPart")
        if root then triggerExplosion(root.Position, Config.ExplosionEffect.Size) end
    end
end

