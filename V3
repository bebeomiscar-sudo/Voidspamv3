-- Aimbot Logic
local aimbotTarget = nil
local aimbotReactionTick = 0
local forgotTimer = 0

local function aimbotLogic()
    if not Config.AimbotEnabled then return end
    if not CameraController then
        CameraController = getCameraController()
    end
    if not CameraController then return end
    
    local target = nil
    
    -- Check Track Dummy first
    if Config.TrackDummyEnabled then
        local dummyFolder = Workspace:FindFirstChild("ShootingRangeEntities")
        if dummyFolder then
            local dummy = dummyFolder:FindFirstChild("Dummy_" .. Config.DummyIndex)
            if dummy then
                local dummyHRP = dummy:FindFirstChild("HumanoidRootPart")
                if dummyHRP then
                    target = {
                        Player = {Name = "Dummy"},
                        HRP = dummyHRP,
                        Humanoid = dummy:FindFirstChildOfClass("Humanoid")
                    }
                end
            end
        end
    end
    
    -- Normal enemy targeting
    if not target then
        target = getClosestEnemy()
    end
    
    if target and target.Player ~= lp then
        -- Reaction delay
        if tick() - aimbotReactionTick < (Config.ReactionTime / 1000) then
            return
        end
        
        -- Check forgot timer
        if tick() - forgotTimer > Config.ForgotTime then
            aimbotTarget = nil
        end
        
        if aimbotTarget ~= target then
            aimbotTarget = target
            aimbotReactionTick = tick()
        end
        
        -- Calculate aim position
        local targetPos = target.HRP.Position
        local targetPart = target.HRP
        
        if Config.TargetPart ~= "Head" and Config.TargetPart ~= "HumanoidRootPart" then
            targetPart = target.HRP.Parent:FindFirstChild(Config.TargetPart) or target.HRP
        end
        
        if targetPart then
            targetPos = targetPart.Position
        end
        
        -- Smooth aiming
        local screenPos = Camera:WorldToViewportPoint(targetPos)
        local mousePos = UserInputService:GetMouseLocation()
        local delta = Vector2.new(screenPos.X - mousePos.X, screenPos.Y - mousePos.Y)
        
        -- Apply smoothing
        local smoothFactor = Config.Smoothness / 100
        delta = delta * smoothFactor
        
        -- Position delays
        local jumpVel = target.HRP.Velocity.Y
        if Config.JumpSmooth > 0 and JumpVel > 2 then
            delta = delta + Vector2.new(0, JumpVel * (Config.JumpSmooth / 100))
        end
        
        if Config.XSmooth > 0 then
            delta = delta * (1 - (Config.XSmooth / 100))
        end
        if Config.YSmooth > 0 then
            delta = delta * (1 - (Config.YSmooth / 100))
        end
        
        -- Set rotation via CameraController
        local currentRot = Camera.CFrame.LookVector
        local targetDir = (targetPos - Camera.CFrame.Position).Unit
        local angleDiff = math.atan2(targetDir.Z, targetDir.X) - math.atan2(currentRot.Z, currentRot.X)
        
        -- Normalize angle
        while angleDiff > math.pi do
            angleDiff = angleDiff - 2 * math.pi
        end
        while angleDiff < -math.pi do
            angleDiff = angleDiff + 2 * math.pi
        end
        
        local newPitch = math.asin(currentRot.Y) + angleDiff * (1 - smoothFactor)
        local newYaw = math.atan2(currentRot.Z, currentRot.X) + angleDiff * (1 - smoothFactor)
        
        pcall(function()
            CameraController:SetRotation(Vector2.new(newPitch, newYaw))
        end)
    end
end

-- Void Spam Logic
local function voidSpamLogic()
    if not Config.VoidSpamEnabled then return end
    if not HRP then return end
    
    local realCF = HRP.CFrame
    local fakePos = nil
    
    if Config.VoidMethod == "Extreme Desync" then
        fakePos = realCF.Position + Vector3.new(
            randomExclude(-2000000000, 2000000000, -1000, 1000),
            randomExclude(-2000000000, 2000000000, -1000, 1000),
            randomExclude(-2000000000, 2000000000, -1000, 1000)
        ) + HRP.Velocity * 0.5
    elseif Config.VoidMethod == "Projectile TP" then
        fakePos = Vector3.new(
            realCF.X + randomExclude(-50, 50, -10, 10),
            Config.Altitude,
            realCF.Z + randomExclude(-50, 50, -10, 10)
        )
    elseif Config.VoidMethod == "Orbital Void" then
        local angle = tick() * 0.5
        fakePos = realCF.Position + Vector3.new(
            math.cos(angle) * 50,
            Config.Altitude,
            math.sin(angle) * 50
        )
    elseif Config.VoidMethod == "Controlled Void" then
        fakePos = Vector3.new(
            randomExclude(-1000, 1000, -100, 100),
            Config.Altitude,
            randomExclude(-1000, 1000, -100, 100)
        )
    elseif Config.VoidMethod == "Seizure Mode" then
        local tickCount = math.floor(tick() * 4)
        local corner = tickCount % 4
        if corner == 0 then
            fakePos = realCF.Position + Vector3.new(1000, 0, 1000)
        elseif corner == 1 then
            fakePos = realCF.Position + Vector3.new(-1000, 0, 1000)
        elseif corner == 2 then
            fakePos = realCF.Position + Vector3.new(0, 0, 1000)
        else
            fakePos = realCF.Position + Vector3.new 0, 0, -1000)
        end
    end
    
    if fakePos then
        HRP.CFrame = CFrame.new(fakePos)
    end
end

