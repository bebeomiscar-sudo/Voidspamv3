-- weapon tracker

local function wtIsEnemy(player)
    if player == lp then return false end
    if Config.WeaponTracker.TeamCheck and sameTeam(player) then return false end
    return isAlive(player)
end

local function wtOnShootStart(shooter)
    if not Config.WeaponTracker.Enabled then return end
    if not wtIsEnemy(shooter) then return end
    wtShootingPlayers[shooter] = true; wtVoidActive = true
    if wtTeleportTask then task.cancel(wtTeleportTask); wtTeleportTask = nil end
end

local function wtOnShootStop(shooter)
    if not Config.WeaponTracker.Enabled then return end
    wtShootingPlayers[shooter] = nil
    local any = false; for _ in pairs(wtShootingPlayers) do any = true; break end
    if any then return end
    wtVoidActive = false
    local target = shooter
    wtTeleportTask = task.delay(Config.WeaponTracker.TeleportDelay, function()
        if not Config.WeaponTracker.Enabled or not isAlive(target) then return end
        local er = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
        local mr = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if er and mr then pcall(function() mr.CFrame = er.CFrame end) end
        wtTeleportTask = nil
    end)
end

local function wtHookPlayer(player)
    if player == lp then return end
    if wtPlayerConnections[player] then return end
    wtPlayerConnections[player] = {}

    local function hookTool(tool)
        local ac = tool.Activated:Connect(function() if Config.WeaponTracker.Enabled then wtOnShootStart(player) end end)
        local dc = tool.Deactivated:Connect(function() if Config.WeaponTracker.Enabled then wtOnShootStop(player) end end)
        local uc = tool.AncestryChanged:Connect(function(_, p) if not p or not p:IsDescendantOf(Workspace) then wtOnShootStop(player) end end)
        table.insert(wtPlayerConnections[player], ac); table.insert(wtPlayerConnections[player], dc); table.insert(wtPlayerConnections[player], uc)
    end

    local function watchChar(char)
        for _, child in ipairs(char:GetChildren()) do if child:IsA("Tool") then task.spawn(hookTool, child) end end
        local ac = char.ChildAdded:Connect(function(child) if child:IsA("Tool") then task.spawn(hookTool, child) end end)
        table.insert(wtPlayerConnections[player], ac)
        local pc = Workspace.ChildAdded:Connect(function(obj)
            if not Config.WeaponTracker.Enabled or obj.Name ~= "CoreProjectile" or not wtIsEnemy(player) then return end
            local root = char:FindFirstChild("HumanoidRootPart"); if not root then return end
            task.defer(function()
                pcall(function()
                    local pp = obj:FindFirstChildOfClass("BasePart") or obj
                    if (pp.Position - root.Position).Magnitude < 30 then
                        wtOnShootStart(player)
                        local rc; rc = obj.AncestryChanged:Connect(function(_, p2) if not p2 then wtOnShootStop(player); rc:Disconnect() end end)
                    end
                end)
            end)
        end)
        table.insert(wtPlayerConnections[player], pc)
    end

    if player.Character then task.spawn(watchChar, player.Character) end
    local cac = player.CharacterAdded:Connect(function(char)
        for i = #wtPlayerConnections[player], 1, -1 do
            pcall(function() wtPlayerConnections[player][i]:Disconnect() end)
            table.remove(wtPlayerConnections[player], i)
        end
        wtOnShootStop(player); task.spawn(watchChar, char)
    end)
    table.insert(wtPlayerConnections[player], cac)
end

local function wtUnhookPlayer(player)
    if not wtPlayerConnections[player] then return end
    for _, conn in ipairs(wtPlayerConnections[player]) do pcall(function() conn:Disconnect() end) end
    wtPlayerConnections[player] = nil; wtOnShootStop(player)
end

local function startWeaponTracker()
