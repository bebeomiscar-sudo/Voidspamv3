-- SAFE LIBRARY LOADER
-- the original crash was here — if HttpGet fails or returns garbage
-- loadstring returns nil and calling nil() = "attempt to call a nil value"
-- we retry up to 3 times before giving up
-- ═══════════════════════════════════════════════════════════════════════

local repo = "https://raw.githubusercontent.com/mstudio45/LinoriaLib/main/"

local function safeLoad(url, label)
    local result = nil
    local lastErr = "unknown"

    for attempt = 1, 3 do
        local httpOk, httpResult = pcall(function()
            return game:HttpGet(url)
        end)

        if not httpOk then
            lastErr = "HttpGet failed: " .. tostring(httpResult)
            warn("[RivalsTool] " .. label .. " attempt " .. attempt .. " — " .. lastErr)
            task.wait(1.5)
            continue
        end

        if not httpResult or httpResult == "" then
            lastErr = "empty response"
            warn("[RivalsTool] " .. label .. " attempt " .. attempt .. " — " .. lastErr)
            task.wait(1.5)
            continue
        end

        local compileOk, compiled = pcall(loadstring, httpResult)

        if not compileOk or not compiled then
            lastErr = "loadstring failed: " .. tostring(compiled)
            warn("[RivalsTool] " .. label .. " attempt " .. attempt .. " — " .. lastErr)
            task.wait(1.5)
            continue
        end

        local runOk, runResult = pcall(compiled)

        if not runOk then
            lastErr = "execution failed: " .. tostring(runResult)
            warn("[RivalsTool] " .. label .. " attempt " .. attempt .. " — " .. lastErr)
            task.wait(1.5)
            continue
        end

        result = runResult
        break
    end

    if not result then
        error("[RivalsTool] Failed to load " .. label .. " after 3 attempts — last error: " .. lastErr, 2)
    end

    return result
end

