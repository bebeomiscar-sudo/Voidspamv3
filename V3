local function FindCoreProjectile()
    for _, obj in ipairs(Workspace:GetChildren()) do
        if obj.Name == "CoreProjectile" and obj:FindFirstChild("TouchInterest") then return obj end
    end
    return nil
end

local function GetEnemyHitbox(enemy)
    if not enemy or not enemy.Character then return nil end
    local targetPart = Config.ProjectileTP.TargetPart
    return enemy.Character:FindFirstChild(targetPart)
        or enemy.Character:FindFirstChild("HitBoxHead")
        or enemy.Character:FindFirstChild("HitBoxHeadSmall")
        or enemy.Character:FindFirstChild("Head")
end

local function createExpandedHitbox(enemy)
    if not enemy or not enemy.Character then return nil end
    local root = enemy.Character:FindFirstChild("HumanoidRootPart"); if not root then return nil end
    local size = Config.ProjectileTP.HitboxSize
    local hitbox = Instance.new("Part")
    hitbox.Name="._ExpandedHitbox"; hitbox.Size=Vector3.new(size,size,size)
    hitbox.CFrame=root.CFrame; hitbox.Anchored=true; hitbox.CanCollide=false; hitbox.Transparency=1; hitbox.Parent=Workspace
    task.delay(1, function() pcall(function() hitbox:Destroy() end) end)
    return hitbox
end

Connections.ProjectileTP = RunService.Heartbeat:Connect(function()
    if not Config.ProjectileTP.Enabled then return end
    if Config.PulseDesync.Enabled and pulsePhase ~= "attack" then return end
    if Config.Ragebot.Enabled and Config.Ragebot.VoidSpamSync and ragebotPhase ~= "attack" then return end
    pcall(function()
        local projectile = FindCoreProjectile(); if not projectile then return end
        if Config.ProjectileTP.Cache and not ProjectileCache[projectile] then ProjectileCache[projectile] = true end
        CacheEnemies()
        for _, enemy in ipairs(EnemyCache) do
