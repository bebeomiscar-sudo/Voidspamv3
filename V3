local function startPulseDesync()
    if pulseTask then task.cancel(pulseTask); pulseTask = nil end
    pulseTask = task.spawn(function()
        while Config.PulseDesync.Enabled do
            local char = lp.Character
            if char then
                local root = char:FindFirstChild("HumanoidRootPart")
                if root then
                    pulseHrp = root; pulseRealCF = root.CFrame; pulseRealV = root.AssemblyLinearVelocity; pulseRealVA = root.AssemblyAngularVelocity
                    pulsePhase = "hide"
                    root.CFrame = CFrame.new(pulseRealCF.Position.X+math.random(-50,50), Config.PulseDesync.VoidAltitude, pulseRealCF.Position.Z+math.random(-50,50))
                    root.AssemblyLinearVelocity = Vector3.zero; root.AssemblyAngularVelocity = Vector3.zero
                    task.wait(Config.PulseDesync.HideTime)
                    pulsePhase = "attack"
                    if pulseHrp and pulseHrp.Parent then
                        pcall(function() pulseHrp.CFrame = pulseRealCF; pulseHrp.AssemblyLinearVelocity = pulseRealV; pulseHrp.AssemblyAngularVelocity = pulseRealVA end)
                    end
                    task.wait(Config.PulseDesync.AttackTime)
                end
            end
            if not Config.PulseDesync.Enabled then break end
        end
        pulseTask = nil; pulsePhase = "attack"
    end)
