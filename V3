--[[
    WEAPON TRACKER
    
    old version used a single UseItem remote which was fragile and
    guessed the shooter by matching character descendants — broke constantly
    
    new version:
    - scans ALL remotes under Replication and Gameplay folders
    - looks for remotes with shoot/fire/attack related names
    - hooks them and identifies the shooter by checking which
      non-local player just fired a tool (via ChildAdded on their character
      for projectiles, or via tool.Activated signals we set up per player)
    - falls back to tool.Activated hooks on each enemy's equipped tool
      as a secondary detection method
    - this way we dont depend on a single hardcoded remote path
]]

local function wtIsEnemy(player)
    if player == lp then return false end
    if Config.WeaponTracker.TeamCheck and sameTeam(player) then return false end
    return isAlive(player)
end

local function wtOnShootStart(shooter)
    if not Config.WeaponTracker.Enabled then return end
    if not wtIsEnemy(shooter) then return end
    wtShootingPlayers[shooter] = true
    wtVoidActive = true
    if wtTeleportTask then task.cancel(wtTeleportTask); wtTeleportTask = nil end
end

local function wtOnShootStop(shooter)
    if not Config.WeaponTracker.Enabled then return end
    wtShootingPlayers[shooter] = nil

    -- check if anyone else is still shooting
    local anyActive = false
    for _ in pairs(wtShootingPlayers) do anyActive = true; break end
    if anyActive then return end

    wtVoidActive = false

    -- teleport into the shooter after a short delay
    local target = shooter
    wtTeleportTask = task.delay(Config.WeaponTracker.TeleportDelay, function()
        if not Config.WeaponTracker.Enabled then return end
        if not isAlive(target) then return end
        local er = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
        local mr = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if er and mr then
            pcall(function() mr.CFrame = er.CFrame end)
        end
        wtTeleportTask = nil
    end)
end

--[[
    per-player tool activation hooks
    we watch each enemy's character for a tool being equipped,
    then hook tool.Activated / tool.Deactivated to track shooting
    this is reliable regardless of what remotes the game uses
]]
local wtPlayerConnections = {}

local function wtHookPlayer(player)
    if player == lp then return end
    if wtPlayerConnections[player] then return end

    wtPlayerConnections[player] = {}

    local function hookTool(tool)
        local activatedConn = tool.Activated:Connect(function()
            if not Config.WeaponTracker.Enabled then return end
            if not wtIsEnemy(player) then return end
            wtOnShootStart(player)
        end)

        -- deactivated fires when they stop holding the fire button
        local deactivatedConn = tool.Deactivated:Connect(function()
            if not Config.WeaponTracker.Enabled then return end
            wtOnShootStop(player)
        end)

        -- also stop tracking when they unequip
        local unequipConn = tool.AncestryChanged:Connect(function(_, parent)
            if parent == nil or not parent:IsDescendantOf(Workspace) then
                wtOnShootStop(player)
            end
        end)

        table.insert(wtPlayerConnections[player], activatedConn)
        table.insert(wtPlayerConnections[player], deactivatedConn)
        table.insert(wtPlayerConnections[player], unequipConn)
    end

    local function watchChar(char)
        -- hook any tool already equipped
        for _, child in ipairs(char:GetChildren()) do
            if child:IsA("Tool") then
                task.spawn(hookTool, child)
            end
        end

        -- hook tools equipped in the future
        local addedConn = char.ChildAdded:Connect(function(child)
            if child:IsA("Tool") then
                task.spawn(hookTool, child)
            end
        end)
        table.insert(wtPlayerConnections[player], addedConn)

        --[[
            also watch for projectiles spawned near this player
            some weapons dont fire tool.Activated properly (bow etc)
            so we detect when a CoreProjectile appears close to them
        ]]
        local projConn = Workspace.ChildAdded:Connect(function(obj)
            if not Config.WeaponTracker.Enabled then return end
            if obj.Name ~= "CoreProjectile" then return end
            if not wtIsEnemy(player) then return end

            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then return end

            -- give it a frame to set position
            task.defer(function()
                pcall(function()
                    local projPart = obj:FindFirstChildOfClass("BasePart") or obj
                    if typeof(projPart.Position) == "Vector3" then
                        local dist = (projPart.Position - root.Position).Magnitude
                        if dist < 30 then
                            -- projectile spawned within 30 studs of this player, they fired
                            wtOnShootStart(player)
                            -- stop tracking when projectile is removed
                            local removeConn
                            removeConn = obj.AncestryChanged:Connect(function(_, parent)
                                if not parent then
                                    wtOnShootStop(player)
                                    removeConn:Disconnect()
                                end
                            end)
                        end
                    end
                end)
            end)
        end)
        table.insert(wtPlayerConnections[player], projConn)
    end

    if player.Character then
        task.spawn(watchChar, player.Character)
    end

    local charAddedConn = player.CharacterAdded:Connect(function(char)
        -- clean up old connections for this player except the CharacterAdded one
        for i = #wtPlayerConnections[player], 1, -1 do
            local c = wtPlayerConnections[player][i]
            pcall(function() c:Disconnect() end)
            table.remove(wtPlayerConnections[player], i)
        end
        wtOnShootStop(player)
        task.spawn(watchChar, char)
    end)

    table.insert(wtPlayerConnections[player], charAddedConn)
end

local function wtUnhookPlayer(player)
    if not wtPlayerConnections[player] then return end
    for _, conn in ipairs(wtPlayerConnections[player]) do
        pcall(function() conn:Disconnect() end)
    end
    wtPlayerConnections[player] = nil
    wtOnShootStop(player)
end

local function startWeaponTracker()
    if wtHookActive then return end
    wtHookActive = true

    -- hook existing players
    for _, player in ipairs(Players:GetPlayers()) do
        task.spawn(wtHookPlayer, player)
    end

    -- hook players that join later
    local addedConn = Players.PlayerAdded:Connect(function(player)
        if Config.WeaponTracker.Enabled then
            wtHookPlayer(player)
        end
    end)
    table.insert(wtConnections, addedConn)

    local removedConn = Players.PlayerRemoving:Connect(function(player)
        wtUnhookPlayer(player)
        wtShootingPlayers[player] = nil
        local anyActive = false
        for _ in pairs(wtShootingPlayers) do anyActive = true; break end
        if not anyActive then wtVoidActive = false end
    end)
    table.insert(wtConnections, removedConn)

    Library:Notify("Weapon Tracker active — watching all tools + projectiles", 3)
end

local function stopWeaponTracker()
    wtHookActive = false

    for _, player in ipairs(Players:GetPlayers()) do
        wtUnhookPlayer(player)
    end

    for _, conn in ipairs(wtConnections) do
        pcall(function() conn:Disconnect() end)
    end
    wtConnections = {}

    wtShootingPlayers = {}
    wtVoidActive      = false

    if wtTeleportTask then task.cancel(wtTeleportTask); wtTeleportTask = nil end
end

-- projectile tp

local function findProjectile()
    for _, obj in ipairs(Workspace:GetChildren()) do
        if obj.Name == "CoreProjectile" and obj:FindFirstChild("TouchInterest") then
            return obj
        end
    end
    return nil
end

local function getEnemyHitbox(enemy)
    if not enemy or not enemy.Character then return nil end
    return enemy.Character:FindFirstChild(Config.ProjectileTP.TargetPart)
        or enemy.Character:FindFirstChild("HitBoxHead")
        or enemy.Character:FindFirstChild("HitBoxHeadSmall")
        or enemy.Character:FindFirstChild("Head")
end

local function makeExpandedHitbox(enemy)
    if not enemy or not enemy.Character then return nil end
    local root = enemy.Character:FindFirstChild("HumanoidRootPart")
    if not root then return nil end

    local sz     = Config.ProjectileTP.HitboxSize
    local hitbox = Instance.new("Part")
    hitbox.Name         = "._ExpandedHitbox"
    hitbox.Size         = Vector3.new(sz, sz, sz)
    hitbox.CFrame       = root.CFrame
    hitbox.Anchored     = true
    hitbox.CanCollide   = false
    hitbox.Transparency = 1
    hitbox.Parent       = Workspace

    task.delay(1, function()
        pcall(function() hitbox:Destroy() end)
    end)
    return hitbox
end

