    if pulseTask then task.cancel(pulseTask); pulseTask = nil end
    if pulseHrp and pulseRealCF and pulseHrp.Parent then
        pcall(function() pulseHrp.CFrame = pulseRealCF; pulseHrp.AssemblyLinearVelocity = pulseRealV or Vector3.zero; pulseHrp.AssemblyAngularVelocity = pulseRealVA or Vector3.zero end)
    end
    pulsePhase = "attack"; pulseHrp = nil
