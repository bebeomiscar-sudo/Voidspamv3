-- RELOAD SPEED
-- ═══════════════════════════════════════════
local reloadPatchedOriginals = {}
local function applyReloadPatch()
    pcall(function()
        local ItemLibrary = require(ReplicatedStorage.Modules.ItemLibrary)
        local Items       = rawget(ItemLibrary, "Items"); if not Items then return end
        for _, Item in Items do
            local Name = Item.Name
            if not table.find(Config.Weapons.Whitelist, Name) then continue end
            if not Item["ReloadLength"] then continue end
            if not reloadPatchedOriginals[Name] then reloadPatchedOriginals[Name] = Item.ReloadLength end
            if Config.Weapons.ReloadSpeedEnabled then
                rawset(Item, "ReloadLength", Name=="Daggers" and math.max(Config.Weapons.ReloadLength, 0.09) or Config.Weapons.ReloadLength)
            else rawset(Item, "ReloadLength", reloadPatchedOriginals[Name]) end
        end
    end)
end

-- ═══════════════════════════════════════════
-- RAKNET HOOK
-- ═══════════════════════════════════════════
local raknetHookActive = false; local raknetHookRef = nil
local function startRakNetHook()
    if raknetHookActive then return end
    local ok = pcall(function()
        raknetHookRef = function(packet)
            if packet.PacketId == 0x1B then local data = packet.AsBuffer; buffer.writeu32(data,1,0xFFFFFFFF); packet:SetData(data) end
        end
        raknet.add_send_hook(raknetHookRef); raknetHookActive = true
    end)
    if not ok then Library:Notify("RakNet hook failed",4); Config.RakNet.Enabled=false end
end
local function stopRakNetHook()
    if not raknetHookActive then return end
    pcall(function() if raknetHookRef then raknet.remove_send_hook(raknetHookRef) end end)
    raknetHookActive=false; raknetHookRef=nil
end

