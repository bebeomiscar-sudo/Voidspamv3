    nameLabel.Text     = p.Name
    objs.name = nameLabel

    -- HP bar (line)
    local hpBar = Drawing.new("Line")
    hpBar.Visible    = false
    hpBar.Color      = Color3.fromRGB(50, 255, 50)
    hpBar.Thickness  = 2
    objs.hp = hpBar

    -- Dist
    local distLabel = Drawing.new("Text")
    distLabel.Visible = false
    distLabel.Color   = Color3.fromRGB(200, 200, 200)
    distLabel.Size    = 12
    distLabel.Center  = true
    distLabel.Outline = true
    objs.dist = distLabel

    espObjects[p] = objs
end

local function updateESP()
    if not CFG.ESP.On then
        for p, _ in pairs(espObjects) do removeESP(p) end
        return
    end
    local cam = workspace.CurrentCamera
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LP then continue end
        if CFG.ESP.TeamCheck and isSameTeam(p) then
            removeESP(p); continue
        end
        if not espObjects[p] then buildESP(p) end
        local objs = espObjects[p]
        if not objs then continue end

        local char = p.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        local head = char and char:FindFirstChild("Head")

        if not hrp or not hum or not head then
            for _, obj in pairs(objs) do pcall(function() obj.Visible = false end) end
            continue
        end

        local dist = (hrp.Position - (getHRP() and getHRP().Position or Vector3.zero)).Magnitude
        if dist > CFG.ESP.MaxDist then
            for _, obj in pairs(objs) do pcall(function() obj.Visible = false end) end
            continue
        end

        -- Project corners of a rough bounding box
        local topPos    = head.Position + Vector3.new(0, 1.5, 0)
        local bottomPos = hrp.Position  - Vector3.new(0, 3,   0)

        local topSP,    topOn    = cam:WorldToViewportPoint(topPos)
        local bottomSP, bottomOn = cam:WorldToViewportPoint(bottomPos)

        if not topOn and not bottomOn then
            for _, obj in pairs(objs) do pcall(function() obj.Visible = false end) end
            continue
        end

        local x1 = math.min(topSP.X, bottomSP.X) - 20
        local y1 = topSP.Y
        local x2 = math.max(topSP.X, bottomSP.X) + 20
        local y2 = bottomSP.Y
        local w  = x2 - x1
        local h  = y2 - y1

        -- Box
        if CFG.ESP.ShowBox and objs.box then
            objs.box.Position    = Vector2.new(x1, y1)
            objs.box.Size        = Vector2.new(w, h)
            objs.box.Visible     = true
        end

        -- Name
        if CFG.ESP.ShowName and objs.name then
            objs.name.Position = Vector2.new((x1+x2)/2, y1 - 16)
            objs.name.Text     = p.Name
            objs.name.Visible  = true
        end

        -- HP bar
        if CFG.ESP.ShowHP and objs.hp then
            local hpPct  = clamp(hum.Health / hum.MaxHealth, 0, 1)
            local barH   = h * hpPct
            local barX   = x1 - 5
            objs.hp.From    = Vector2.new(barX, y2)
            objs.hp.To      = Vector2.new(barX, y2 - barH)
            objs.hp.Color   = Color3.fromRGB(
                math.floor((1-hpPct)*255),
                math.floor(hpPct*255),
                0
            )
            objs.hp.Visible = true
        end

        -- Distance
        if CFG.ESP.ShowDist and objs.dist then
            objs.dist.Position = Vector2.new((x1+x2)/2, y2 + 2)
            objs.dist.Text     = string.format("%.0f", dist)
            objs.dist.Visible  = true
        end
    end
end

