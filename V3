local function getBestPart(char, setting)
    local preset = PART_PRESETS[setting] or { "Head" }
    if preset[1] == "Random" then
        local available = {}
        for _, pn in ipairs(ALL_PARTS) do
            local p = char:FindFirstChild(pn)
            if p then table.insert(available, p) end
        end
        return #available > 0 and available[math.random(#available)] or nil
    end
    for _, pn in ipairs(preset) do
        local p = char:FindFirstChild(pn)
        if p then return p end
    end
    for _, pn in ipairs(ALL_PARTS) do
        local p = char:FindFirstChild(pn)
        if p then return p end
    end
    return nil
end

local function getEnemiesSorted()
    local list   = {}
    local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")

    for _, player in ipairs(Players:GetPlayers()) do
        if player == lp then continue end
        if not isAlive(player) then continue end
        if Config.ProjectileTP.TeamCheck and sameTeam(player) then continue end

        local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if root and myRoot then
            local dist = (myRoot.Position - root.Position).Magnitude
            if dist > Config.ProjectileTP.MaxDistance then continue end
            if Config.ProjectileTP.VisCheck and not visibleFrom(myRoot.Position, root) then continue end
            table.insert(list, { player = player, dist = dist })
        end
    end

    local p = Config.ProjectileTP.Priority
    if p == "Closest" then
        table.sort(list, function(a, b) return a.dist < b.dist end)
    elseif p == "Furthest" then
        table.sort(list, function(a, b) return a.dist > b.dist end)
    elseif p == "Random" then
        for i = #list, 2, -1 do
            local j = math.random(i)
            list[i], list[j] = list[j], list[i]
        end
    elseif p == "Lowest HP" then
        table.sort(list, function(a, b)
            local ha = a.player.Character:FindFirstChildOfClass("Humanoid")
            local hb = b.player.Character:FindFirstChildOfClass("Humanoid")
            return (ha and ha.Health or 0) < (hb and hb.Health or 0)
        end)
    elseif p == "Highest HP" then
        table.sort(list, function(a, b)
            local ha = a.player.Character:FindFirstChildOfClass("Humanoid")
            local hb = b.player.Character:FindFirstChildOfClass("Humanoid")
            return (ha and ha.Health or 0) > (hb and hb.Health or 0)
        end)
    end

    local out = {}
    for _, e in ipairs(list) do table.insert(out, e.player) end
    return out
end

