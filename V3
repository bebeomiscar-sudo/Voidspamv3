local function playAnimation(animId, looped, speed)
    if PlayAnimFn then
        pcall(function() PlayAnimFn(animId, looped, speed) end)
        return
    end
    pcall(function()
        local char = LocalPlayer.Character
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        local animator = hum:FindFirstChildOfClass("Animator") or Instance.new("Animator", hum)
        if activeAnimTrack then pcall(function() activeAnimTrack:Stop() end); activeAnimTrack = nil end
        local anim = Instance.new("Animation")
        anim.AnimationId = "rbxassetid://" .. tostring(animId):gsub("[^%d]","")
        local track = animator:LoadAnimation(anim)
        track.Looped = looped or false
        track:AdjustSpeed(speed or 1)
        track:Play()
        activeAnimTrack = track
        anim:Destroy()
    end)
end

local function stopAnimation()
    if activeAnimTrack then pcall(function() activeAnimTrack:Stop() end); activeAnimTrack = nil end
end

