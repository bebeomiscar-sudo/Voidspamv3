    if #enemies > 0 then return enemies[1] end
    return nil
end

local function startRagebotLoop()
    if ragebotLoopTask then task.cancel(ragebotLoopTask); ragebotLoopTask = nil end

    ragebotLoopTask = task.spawn(function()
        while Config.Ragebot.Enabled do
            local enemy  = ragebotGetTarget()
            local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")

            if enemy and enemy.Character and myRoot then
                local enemyRoot = enemy.Character:FindFirstChild("HumanoidRootPart")

                if enemyRoot then
                    ragebotCurrentTarget = enemy

                    if Config.Ragebot.VoidSpamSync then
                        -- HIDE PHASE: orbit enemy at void altitude (server can't hit you)
                        ragebotPhase = "hide"
                        if Config.Ragebot.ClientTP then
                            local t      = tick() * Config.Ragebot.OrbitSpeed
                            local radius = Config.Ragebot.OrbitRadius
                            enemyRoot.CFrame = CFrame.new(
                                myRoot.Position + Vector3.new(math.sin(t)*radius, 0, math.cos(t)*radius)
                            )
                        end
                        task.wait(Config.Ragebot.HideTime)

                        -- ATTACK PHASE: real position, fire projectiles
                        ragebotPhase = "attack"
                        task.wait(Config.Ragebot.AttackTime)
                    else
                        -- Simple orbit without timing
                        ragebotPhase = "attack"
                        if Config.Ragebot.ClientTP then
                            local t      = tick() * Config.Ragebot.OrbitSpeed
                            local radius = Config.Ragebot.OrbitRadius
                            enemyRoot.CFrame = CFrame.new(
                                myRoot.Position + Vector3.new(math.sin(t)*radius, 0, math.cos(t)*radius)
                            )
                        end
                        task.wait(0.05)
                    end
                end
            else
                ragebotPhase = "attack"
                task.wait(0.1)
            end

            if not Config.Ragebot.Enabled then break end
        end

        ragebotLoopTask = nil
        ragebotPhase    = "attack"
    end)
end

local function stopRagebotLoop()
    if ragebotLoopTask then task.cancel(ragebotLoopTask); ragebotLoopTask = nil end
    ragebotPhase = "attack"
end

-- Ragebot persistence: re-enable after round/character reset
local function setupRagebotPersistence()
    if ragebotPersistConn then ragebotPersistConn:Disconnect() end

    ragebotPersistConn = LocalPlayer.CharacterAdded:Connect(function(character)
        if not Config.Ragebot.PersistAcrossRounds then return end
        if not ragebotWasEnabled then return end

        -- Wait for character to fully load
        character:WaitForChild("HumanoidRootPart", 10)
        task.wait(1.5)

        -- Re-enable ragebot
        if not Config.Ragebot.Enabled then
            Config.Ragebot.Enabled = true
            startRagebotLoop()
            Library:Notify("Ragebot auto-resumed after round", 3)
        end
    end)
end

-- Track when ragebot was manually enabled
local function enableRagebot()
    Config.Ragebot.Enabled = true
    ragebotWasEnabled      = true
    startRagebotLoop()
    setupRagebotPersistence()
end

local function disableRagebot()
    Config.Ragebot.Enabled = false
    ragebotWasEnabled      = false
    stopRagebotLoop()
end

-- ═══════════════════════════════════════════
-- WEAPON TRACKER SYSTEM
-- ═══════════════════════════════════════════
local WT_START_NAMES = {"StartShooting", "Shooting"}
local WT_STOP_NAMES  = {"StopShooting", "Reload", "StartReloading"}

local function wtIsEnemy(player)
    if player == LocalPlayer then return false end
    if Config.WeaponTracker.TeamCheck and isSameTeam(player) then return false end
    return IsAlive(player)
end

local function wtOnEnemyShootStart(shooter)
    if not Config.WeaponTracker.Enabled then return end
    if not wtIsEnemy(shooter) then return end
    wtShootingPlayers[shooter] = true
    wtEnemyShooting = true
    wtLastShooter   = shooter
    wtVoidActive    = true
    if wtTeleportTask then task.cancel(wtTeleportTask); wtTeleportTask = nil end
end

local function wtOnEnemyShootStop(shooter)
    if not Config.WeaponTracker.Enabled then return end
    wtShootingPlayers[shooter] = nil
    local anyStillShooting = false
    for _ in pairs(wtShootingPlayers) do anyStillShooting = true; break end

    if not anyStillShooting then
        wtEnemyShooting = false
        wtVoidActive    = false
        local shooter_ref = shooter
        wtTeleportTask = task.delay(Config.WeaponTracker.TeleportDelay, function()
            if not Config.WeaponTracker.Enabled then return end
            if not IsAlive(shooter_ref) then return end
            local enemyRoot = shooter_ref.Character and shooter_ref.Character:FindFirstChild("HumanoidRootPart")
            local myRoot    = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if enemyRoot and myRoot then
                pcall(function() myRoot.CFrame = enemyRoot.CFrame end)
            end
            wtTeleportTask = nil
        end)
    end
end

local function startWeaponTrackerHook()
    if wtHookActive then return end
    local ok = pcall(function()
        local UseItemRemote = ReplicatedStorage.Remotes.Replication.Fighter.UseItem
        local conn = UseItemRemote.OnClientEvent:Connect(function(fighterOrPlayer, enumAction)
            if not Config.WeaponTracker.Enabled then return end
            local shooter = nil
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer then
                    local char = p.Character
                    if char then
                        local ok2, result = pcall(function()
                            if typeof(fighterOrPlayer) == "Instance" then
                                return fighterOrPlayer:IsDescendantOf(char)
                            end
                            return fighterOrPlayer == p
                        end)
                        if ok2 and result then shooter = p; break end
                    end
                end
            end
            if not shooter then shooter = GetClosestEnemy() end
            if not shooter then return end

            local actionStr = tostring(enumAction)
            local isStart, isStop = false, false
            for _, name in ipairs(WT_START_NAMES) do
                if string.find(actionStr, name, 1, true) then isStart = true; break end
            end
            if not isStart then
                for _, name in ipairs(WT_STOP_NAMES) do
                    if string.find(actionStr, name, 1, true) then isStop = true; break end
                end
            end
            if isStart then wtOnEnemyShootStart(shooter)
            elseif isStop then wtOnEnemyShootStop(shooter) end
        end)
        table.insert(antiOOBConnections, conn)
        wtHookActive = true
    end)
    if not ok then Library:Notify("Weapon Tracker: hook failed", 3) end
end

local function stopWeaponTrackerHook()
    wtHookActive = false; wtEnemyShooting = false; wtVoidActive = false
    wtShootingPlayers = {}
    if wtTeleportTask then task.cancel(wtTeleportTask); wtTeleportTask = nil end
end

