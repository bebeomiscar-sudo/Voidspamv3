local function startTracerHooks()
    for _, c in ipairs(tracerConnections) do pcall(function() c:Disconnect() end) end; tracerConnections = {}
    local char = lp.Character; if not char then return end
    local function hookTool(tool)
        local conn = tool.Activated:Connect(function()
            if not Config.TracerEffect.Enabled or not Config.TracerEffect.OnShoot then return end
            pcall(function()
                local myRoot = char:FindFirstChild("HumanoidRootPart"); if not myRoot then return end
                local toPos
                if Config.TracerEffect.TraceToEnemy then
                    local e = getClosestEnemy()
                    if e and e.Character then local r = e.Character:FindFirstChild("HumanoidRootPart"); if r then toPos = r.Position end end
                else local cam = Workspace.CurrentCamera; toPos = cam.CFrame.Position + cam.CFrame.LookVector * 200 end
                if toPos then playTracer(myRoot.Position, toPos) end
            end)
        end)
        table.insert(tracerConnections, conn)
    end
    for _, child in ipairs(char:GetChildren()) do if child:IsA("Tool") then hookTool(child) end end
    local c = char.ChildAdded:Connect(function(child) if child:IsA("Tool") then hookTool(child) end end)
