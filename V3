-- ANTI PROJECTILE
-- watches for CoreProjectiles near us and sends them to the void
-- works for both standalone and as part of OmegaBot
-- ═══════════════════════════════════════════════════════════════════════

local function deflectProjectile(proj, reason)
    pcall(function()
        local alt = Config.AntiProjectile.Enabled
            and Config.AntiProjectile.VoidAltitude
            or Config.OmegaBot.AntiProjAltitude

        if Config.AntiProjectile.RedirectToSelf and Config.AntiProjectile.Enabled then
            -- teleport it under us (harmless, also funny)
            local char = lp.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if root then
                proj.CFrame = CFrame.new(root.Position + Vector3.new(0, -10, 0))
            end
        else
            -- send to void
            proj.CFrame = CFrame.new(math.random(-1000,1000), alt, math.random(-1000,1000))
        end
        proj.AssemblyLinearVelocity  = Vector3.zero
        proj.AssemblyAngularVelocity = Vector3.zero

        omegaDeflectCount += 1
        if Config.AntiProjectile.LogDeflects then
            Library:Notify("Deflected projectile [" .. reason .. "] #" .. omegaDeflectCount, 1)
        end
    end)
end

local function isEnemyProjectile(proj)
    -- try to figure out if this projectile belongs to an enemy
    -- check proximity to enemy characters at spawn time
    local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return false end

    -- if it spawned close to an enemy and is heading toward us it's hostile
    local projPos = pcall(function() return proj.Position end) and proj.Position or nil
    if not projPos then return false end

    for _, player in ipairs(Players:GetPlayers()) do
        if player == lp then continue end
        if Config.AntiProjectile.Enabled and sameTeam(player) then continue end
        if Config.OmegaBot.TeamCheck and sameTeam(player) then continue end
        local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if root then
            -- spawned within 35 studs of an enemy = their projectile
            if (projPos - root.Position).Magnitude < 35 then
                return true, player
            end
        end
    end
    return false
end

local function startAntiProjectile()
    for _, c in ipairs(antiProjConnections) do pcall(function() c:Disconnect() end) end
    antiProjConnections = {}
    antiProjActive      = true

    local conn = Workspace.ChildAdded:Connect(function(obj)
        if not (Config.AntiProjectile.Enabled or Config.OmegaBot.AntiProjectile) then return end
        if obj.Name ~= "CoreProjectile" then return end

        task.defer(function()
            -- give it a frame to get its position set
            local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if not myRoot then return end

            pcall(function()
                local radius = Config.AntiProjectile.Enabled
                    and Config.AntiProjectile.Radius
                    or Config.OmegaBot.AntiProjRadius

                -- check every frame if it's getting close to us
                local checkConn
                local frames = 0
                checkConn = RunService.Heartbeat:Connect(function()
                    frames += 1
                    if frames > 120 then checkConn:Disconnect(); return end  -- stop after 2 seconds
                    if not obj or not obj.Parent then checkConn:Disconnect(); return end

                    local ok, projPos = pcall(function() return obj.Position end)
                    if not ok then checkConn:Disconnect(); return end

                    local dist = (projPos - myRoot.Position).Magnitude
                    if dist < radius then
                        local isEnemy = isEnemyProjectile(obj)
                        if isEnemy then
                            deflectProjectile(obj, "proximity " .. math.floor(dist) .. "st")
                            checkConn:Disconnect()
                        end
                    end
                end)
            end)
        end)
    end)
    table.insert(antiProjConnections, conn)
end

local function stopAntiProjectile()
    antiProjActive = false
    for _, c in ipairs(antiProjConnections) do pcall(function() c:Disconnect() end) end
    antiProjConnections = {}
end

-- ═══════════════════════════════════════════════════════════════════════
-- PROJECTILE MIMIC
--[[
    when an enemy fires a CoreProjectile:
    1. we detect it spawned near them
    2. we fire firetouchinterest from THEIR projectile onto THEIR hitbox
    3. effectively their own shot registers on them
    4. optional: also hits every other enemy with the same projectile
    
    this is different from normal projectile TP because:
    - we're using the ENEMY'S projectile, not ours
    - it fires as soon as they shoot, before it can reach us
    - we don't need to shoot first
]]
-- ═══════════════════════════════════════════════════════════════════════

local function mimicFire(proj, shooter)
    if not proj or not proj.Parent then return end
    if not shooter or not shooter.Character then return end
    if Config.ProjectileMimic.TeamCheck and sameTeam(shooter) then return end

    local hitName = Config.ProjectileMimic.HitboxPart

    local function fireOnChar(char)
        if not char then return end
        local part = char:FindFirstChild(hitName)
            or char:FindFirstChild("HitBoxHead")
            or char:FindFirstChild("HitBoxHeadSmall")
            or char:FindFirstChild("Head")
        if not part then return end

        for _ = 1, Config.ProjectileMimic.Attempts do
            pcall(function() firetouchinterest(proj, part, 0) end)
            task.wait(0.01)
            pcall(function() firetouchinterest(proj, part, 1) end)
        end
    end

    -- fire on the shooter themselves (their own shot hits them)
    if Config.ProjectileMimic.HitShooter then
        task.spawn(fireOnChar, shooter.Character)
    end

    -- also fire on all other enemies with this projectile
    for _, player in ipairs(Players:GetPlayers()) do
        if player == lp then continue end
        if player == shooter then continue end
        if Config.ProjectileMimic.TeamCheck and sameTeam(player) then continue end
        if not isAlive(player) then continue end
        task.spawn(fireOnChar, player.Character)
    end

    omegaMimicCount += 1
    if Config.ProjectileMimic.LogMimics then
        Library:Notify("Mimic fired from " .. shooter.Name .. " proj #" .. omegaMimicCount, 1)
    end
end

local function startProjectileMimic()
    for _, c in ipairs(mimicConnections) do pcall(function() c:Disconnect() end) end
    mimicConnections     = {}
    mimicSeenProjectiles = {}
    mimicActive          = true

    local conn = Workspace.ChildAdded:Connect(function(obj)
        if not Config.ProjectileMimic.Enabled then return end
        if obj.Name ~= "CoreProjectile" then return end
        if mimicSeenProjectiles[obj] then return end
        mimicSeenProjectiles[obj] = true

        task.defer(function()
            -- identify whose projectile this is
            local shooter = nil
            local myRoot  = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")

            pcall(function()
                local projPos = obj.Position
                for _, player in ipairs(Players:GetPlayers()) do
                    if player == lp then continue end
                    if not isAlive(player) then continue end
                    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                    if root and (projPos - root.Position).Magnitude < 35 then
                        shooter = player
                        break
                    end
                end
            end)

            if not shooter then return end
            if Config.ProjectileMimic.TeamCheck and sameTeam(shooter) then return end

            local delay = Config.ProjectileMimic.MimicDelay / 1000
            if delay > 0 then task.wait(delay) end

            mimicFire(obj, shooter)

            -- clean up seen table when projectile is removed
            obj.AncestryChanged:Connect(function(_, parent)
                if not parent then mimicSeenProjectiles[obj] = nil end
            end)
        end)
    end)

    table.insert(mimicConnections, conn)
end

local function stopProjectileMimic()
    mimicActive          = false
    mimicSeenProjectiles = {}
    for _, c in ipairs(mimicConnections) do pcall(function() c:Disconnect() end) end
    mimicConnections = {}
end

-- ═══════════════════════════════════════════════════════════════════════
-- AIMBOT
-- ═══════════════════════════════════════════════════════════════════════

local function aimbotFOV()
    local f = Config.Aimbot.MaxFOV
    if Config.Aimbot.DynamicFOV then f = f * (camera.FieldOfView / 70) end
    return f
end

local function inFOV(part)
    if not part then return false end
    local sp, onScreen = camera:WorldToViewportPoint(part.Position)
    if not onScreen then return false end
    return (Vector2.new(sp.X, sp.Y) - screenCenter()).Magnitude <= aimbotFOV()
end

local function resetDelayed() delayedTargetPos = nil end

local function getDelayedPos(part, dt)
    if not part or not part.Parent then delayedTargetPos = nil; return nil end
    local real = part.Position
    if not delayedTargetPos then delayedTargetPos = real; return real end
    local jumping = false
    pcall(function()
        local r = part.Parent:FindFirstChild("HumanoidRootPart")
        if r then jumping = r.AssemblyLinearVelocity.Y > 2 end
    end)
    local bf = 60 * dt
    local xA = math.clamp((1 - Config.Aimbot.XSmooth) * (1 + bf), 0.01, 1)
    local yA = (jumping and Config.Aimbot.JumpSmooth > 0)
        and math.clamp((1 - Config.Aimbot.JumpSmooth) * (1 + bf), 0.01, 1)
        or  math.clamp((1 - Config.Aimbot.YSmooth)    * (1 + bf), 0.01, 1)
    delayedTargetPos = Vector3.new(
        delayedTargetPos.X + (real.X - delayedTargetPos.X) * xA,
        delayedTargetPos.Y + (real.Y - delayedTargetPos.Y) * yA,
        delayedTargetPos.Z + (real.Z - delayedTargetPos.Z) * xA
    )
    return delayedTargetPos
end

local function targetStillValid(part)
    if not part or not part.Parent then return false end
    if not isPlayerCharacter(part.Parent) then return false end
    local hum = part.Parent:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if not inFOV(part) then return false end
    if Config.Aimbot.VisibleCheck and not visibleFrom(camera.CFrame.Position, part) then return false end
    if Config.Aimbot.TeamCheck then
        local p = Players:GetPlayerFromCharacter(part.Parent)
        if p and sameTeam(p) then return false end
    end
    return true
end

local function findTarget()
    local c = screenCenter(); local eFOV = aimbotFOV(); local best, bestDist = nil, eFOV
    for _, player in ipairs(Players:GetPlayers()) do
        if player == lp then continue end
        if Config.Aimbot.TeamCheck and sameTeam(player) then continue end
        local ch = player.Character; if not ch then continue end
        local hum = ch:FindFirstChildOfClass("Humanoid"); if not hum or hum.Health <= 0 then continue end
        if not isPlayerCharacter(ch) then continue end
        local part = getBestPart(ch, Config.Aimbot.TargetPart); if not part then continue end
        local sp, onScreen = camera:WorldToScreenPoint(part.Position); if not onScreen then continue end
        local dist = (Vector2.new(sp.X, sp.Y) - c).Magnitude; if dist > eFOV then continue end
        if Config.Aimbot.VisibleCheck and not visibleFrom(camera.CFrame.Position, part) then continue end
        if dist < bestDist then bestDist = dist; best = part end
    end
    return best
end

local function getDummyPart()
    local entities = Workspace:FindFirstChild("ShootingRangeEntities")
    if not entities then return nil end
    local children = entities:GetChildren(); if #children == 0 then return nil end
    local dummy = children[math.clamp(Config.TrackDummy.DummyIndex, 1, #children)]
    if not dummy then return nil end
    return getBestPart(dummy, Config.Aimbot.TargetPart)
        or dummy:FindFirstChild("HumanoidRootPart")
        or dummy:FindFirstChildOfClass("BasePart")
end

local function rotateTo(pos, smoothness)
    if not CameraController then return end
    pcall(function()
        local cp  = camera.CFrame.Position
        local dir = (pos - cp).Unit
        local tP  = math.asin(math.clamp(dir.Y, -1, 1))
        local tY  = math.atan2(-dir.X, -dir.Z)
        local sm  = math.clamp(1 / math.max(smoothness or Config.Aimbot.Smoothness, 0.1), 0.01, 1)
        local cur = CameraController.Rotation
        CameraController:SetRotation(Vector2.new(
            cur.X + (tP - cur.X) * sm,
            cur.Y + angleDiff(cur.Y, tY) * sm
        ))
    end)
end

local function runAimbot(dt)
    if not Config.Aimbot.Enabled and not Config.TrackDummy.Enabled then return end
    if fovCircle then
        fovCircle.Position = screenCenter()
        fovCircle.Radius   = aimbotFOV()
        fovCircle.Visible  = Config.Aimbot.DrawFOV and Config.Aimbot.FOVStyle ~= "Invisible"
            and (Config.Aimbot.Enabled or Config.TrackDummy.Enabled)
    end
    if not CameraController then return end

    if Config.TrackDummy.Enabled then
        local part = getDummyPart()
        if part then rotateTo(part.Position) end
        return
    end

    if not Config.Aimbot.Enabled then return end
    if isInReaction then
        reactionTimer -= dt
        if reactionTimer <= 0 then isInReaction = false end
        return
    end

    if lockedTarget and not targetStillValid(lockedTarget) then
        lockedTarget = nil; lockTimer = 0; resetDelayed()
    end
    if not lockedTarget then
        local t = findTarget()
        if t then
            lockedTarget = t; lockTimer = 0
            isInReaction = true; reactionTimer = Config.Aimbot.ReactionTime / 1000
            resetDelayed()
        end
        return
    end

    lockTimer += dt
    if lockTimer > Config.Aimbot.ForgotTime then
        lockedTarget = nil; lockTimer = 0; resetDelayed(); return
    end

    if inFOV(lockedTarget) then
        local aimPos = getDelayedPos(lockedTarget, dt)
        if aimPos then rotateTo(aimPos) end
    else
        lockedTarget = nil; lockTimer = 0; resetDelayed()
    end
end

