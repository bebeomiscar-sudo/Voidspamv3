-- Stats update loop
RunService.Heartbeat:Connect(function()
    pcall(function()
        if not statLabels.cycles then return end
        statLabels.cycles:UpdateText("Void Cycles: "       .. CFG.Stats.CycleCount)
        statLabels.kills:UpdateText("Kills: "              .. CFG.Stats.KillCount)
        statLabels.evaded:UpdateText("Projectiles Evaded: ".. CFG.Stats.ProjectilesEvaded)
        statLabels.switches:UpdateText("Bypass Switches: " .. CFG.Stats.BypassSwitches)
        statLabels.bypassNow:UpdateText("Current Bypass: "
            .. (CFG.Bypass.Mode == "Adaptive" and VoidState.AdaptiveMode or CFG.Bypass.Mode))
        statLabels.method:UpdateText("Current Method: "    .. CFG.Void.Method)
        statLabels.active:UpdateText("Void Active: "       .. (VoidState.Active and "YES ⚡" or "NO"))
        statLabels.groundY:UpdateText("Ground Y: "         .. math.floor(VoidState.GroundY))
        statLabels.corrections:UpdateText("Server Corrections: " .. VoidState.CorrectionCount)
        statLabels.rbshots:UpdateText("Ragebot Shots: "    .. CFG.Stats.RagebotShots)
        statLabels.wbteles:UpdateText("Wall Bang Teleports: " .. CFG.Stats.WallBangTeleports)
        statLabels.rbactive:UpdateText("Ragebot Active: "  .. (RagebotState.active and "YES ⚡" or "NO"))
        local targetName = "None"
        if RagebotState.currentTarget then
            local p = Players:GetPlayerFromCharacter(RagebotState.currentTarget)
            if p then targetName = p.Name end
        end
        statLabels.rbtarget:UpdateText("Ragebot Target: " .. targetName)
    end)
end)

