local function antiOOB_HideOOBParts(hide)
    for _, part in ipairs(CollectionService:GetTagged("OutOfBoundsPart")) do pcall(function() if hide then part.Transparency=1 end end) end
    for _, part in ipairs(CollectionService:GetTagged("OutOfBoundsSafePart")) do pcall(function() if hide then part.Transparency=1 end end) end
end

local function antiOOB_PatchModule()
    if antiOOBModulePatched then return end
    pcall(function()
        local OOBMachine = require(ReplicatedStorage.Modules.OutOfBoundsMachine)
        if OOBMachine then
            if OOBMachine.IsOutOfBounds then OOBMachine.IsOutOfBounds = function() return nil end end
            if OOBMachine.Update then OOBMachine.Update = function() end end
        end
        antiOOBModulePatched = true; Library:Notify("Anti OOB: Module patched ✓", 2)
    end)
end

local function antiOOB_SpoofRemote()
    if antiOOBHookActive then return end
    local ok = pcall(function()
        local OOBRemote = ReplicatedStorage.Remotes.Replication.Fighter.OutOfBounds
        antiOOBHookRef = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
            local method = getnamecallmethod()
            if (method == "FireServer" or method == "InvokeServer") and self == OOBRemote then
                if Config.AntiOOB.SpoofRemote then return end
            end
            return antiOOBHookRef(self, ...)
        end))
        antiOOBHookActive = true; Library:Notify("Anti OOB: Remote spoof ✓", 2)
    end)
    if not ok then Library:Notify("Anti OOB: hookmetamethod not supported", 3) end
end

local function antiOOB_StopSpoofRemote()
    if not antiOOBHookActive then return end
    pcall(function() if antiOOBHookRef then hookmetamethod(game, "__namecall", antiOOBHookRef) end end)
    antiOOBHookActive = false; antiOOBHookRef = nil
end

local function startAntiOOB()
    if Config.AntiOOB.SpoofRemote then antiOOB_SpoofRemote() end
    if Config.AntiOOB.PatchModule  then antiOOB_PatchModule() end
    if Config.AntiOOB.HideOOBParts then antiOOB_HideOOBParts(true) end
    local c1 = CollectionService:GetInstanceAddedSignal("OutOfBoundsPart"):Connect(function(part) if Config.AntiOOB.Enabled and Config.AntiOOB.HideOOBParts then pcall(function() part.Transparency=1 end) end end)
    local c2 = CollectionService:GetInstanceAddedSignal("OutOfBoundsSafePart"):Connect(function(part) if Config.AntiOOB.Enabled and Config.AntiOOB.HideOOBParts then pcall(function() part.Transparency=1 end) end end)
    table.insert(antiOOBConnections, c1); table.insert(antiOOBConnections, c2)
end

local function stopAntiOOB()
    Config.AntiOOB.Enabled = false; antiOOB_StopSpoofRemote()
    for _, conn in ipairs(antiOOBConnections) do pcall(function() conn:Disconnect() end) end
    antiOOBConnections = {}
end

