local function antiOOB_PatchModule()
    if antiOOBModulePatched then return end
    pcall(function()
        local m = require(ReplicatedStorage.Modules.OutOfBoundsMachine)
        if m then
            if m.IsOutOfBounds then m.IsOutOfBounds = function() return nil end end
            if m.Update then m.Update = function() end end
        end
        antiOOBModulePatched = true; Library:Notify("Anti OOB: module patched", 2)
    end)
end

local function antiOOB_SpoofRemote()
    if antiOOBHookActive then return end
    local ok = pcall(function()
        local remote = ReplicatedStorage.Remotes.Replication.Fighter.OutOfBounds
        antiOOBHookRef = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
            local method = getnamecallmethod()
            if (method == "FireServer" or method == "InvokeServer") and self == remote then
                if Config.AntiOOB.SpoofRemote then return end
            end
            return antiOOBHookRef(self, ...)
        end))
        antiOOBHookActive = true; Library:Notify("Anti OOB: remote spoofed", 2)
    end)
    if not ok then Library:Notify("Anti OOB: hookmetamethod unavailable", 3) end
end

local function antiOOB_StopSpoof()
    if not antiOOBHookActive then return end
    pcall(function() if antiOOBHookRef then hookmetamethod(game, "__namecall", antiOOBHookRef) end end)
    antiOOBHookActive = false; antiOOBHookRef = nil
end

