-- Orbit Logic
local function orbitLogic()
    if not Config.OrbitEnabled then return end
    
    local target = ragebotTarget
    if not target then
        local enemies = getEnemiesSorted()
        for _, enemy in ipairs(enemies) do
            target = enemy
            break
        end
    end
    
    if not target then return end
    
    local targetHRP = target.HRP
    local targetPos = targetHRP.Position
    
    if Config.OrbitResolver then
        targetPos = targetPos + targetHRP.Velocity * (1/30)
    end
    
    _orbitAngle = _orbitAngle + (Config.OrbitSpeed / 10 * Config.OrbitTPDelay)
    local orbitPos = targetPos + Vector3.new(
        math.cos(_orbitAngle) * Config.OrbitRadius,
        0,
        math.sin(_orbitAngle) * Config.OrbitRadius
    )
    
    if Config.OrbitAntiRiot then
        orbitPos = orbitPos + Vector3.new(0, 0, math.pi)
    end
    
    if Config.OrbitAura then
        HRP.CFrame = CFrame.new(orbitPos + Vector3.new(0, Config.Altitude, 0))
    end
    
    _shotTimer = _shotTimer + Config.OrbitTPDelay
    if _shotTimer >= Config.OrbitShotInterval then
        -- Fire logic would go here
        _shotTimer = 0
    end
end

-- Ragebot Logic
local function ragebotLogic()
    if not Config.RagebotEnabled then return end
    if not HRP then return end
    
    if ragebotPhase == "hide" then
        if Config.VoidSpamSync then
            pulsePhase = "hide"
        end
        if Config.ClientTPEnabled then
            local enemies = getEnemiesSorted()
            if enemies[1] then
                local orbitPos = enemies[1].HRP.Position + Vector3.new(
                    math.cos(_orbitAngle) * Config.RageOrbitRadius,
                    0,
                    math.sin(_orbitAngle) * Config.RageOrbitRadius
                )
                HRP.CFrame = CFrame.new(orbitPos)
            end
        end
        task.wait(Config.RageHideTime / 1000)
        ragebotPhase = "attack"
    elseif ragebotPhase == "attack" then
        -- Attack logic here
        for i = 1, Config.RageShootAttempts do
            -- Simulate shooting
            task.wait(0.05)
        end
        
        if Config.VoidSpamSync then
            pulsePhase = "attack"
        end
        task.wait(Config.RageAttackTime / 1000)
        ragebotPhase = "hide"
    end
end

-- Projectile TP Logic
local function findProjectile()
    for _, obj in ipairs(Workspace:GetChildren()) do
        if obj.Name == "CoreProjectile" then
            local touchInterest = obj:FindFirstChild("TouchInterest")
            if touchInterest then
                return obj
            end
        end
    end
    return nil
end

local function getEnemyHitbox()
    local hitboxNames = {"HitBoxHeadSmall", "HitBoxHead", "Head", "HumanoidRootPart"}
    for _, name in ipairs(hitboxNames) do
        if name == Config.ProjTargetHitbox then
            return name
        end
    end
    return "HumanoidRootPart"
end
end

local function projectileTPLogic()
    if not Config.ProjTPEnabled then return end
    if ProjTPBusy then return end
    
    ProjTPBusy = true
    task.spawn(function()
        local projectile = findProjectile()
        if not Projectile then
            ProjTPBusy = false
            return
        end
        
        local hitboxName = getEnemyHitbox()
        local enemies = getEnemiesSorted()
        
        for _, enemy in ipairs(enemies) do
            local hitbox = enemy.HRP.Parent:FindFirstChild(hitboxName)
            if not hitbox then
                hitbox = enemy.HRP
            end
            
            pcall(function()
                fireTouchInterest(Projectile, hitbox, 0)
                task.wait(Config.ProjLoopDelay / 1000)
                FireTouchInterest(Projectile, hitbox, 1)
                
                if Config.HitboxSize > 5 then
                    local expanded = Instance.new("Part")
                    expanded.Size = Vector3.new(Config.HitboxSize, Config.HitboxSize, Config.HitboxSize)
                    expanded.CFrame = hitbox.CFrame
                    expanded.Anchored = true
                    expanded.CanCollide = false
                    expanded.Transparency = 1
                    expanded.Parent = Workspace
                    
                    task.delay(Config.ProjLoopDelay / 1000 + 0.1, function()
                        pcall(function()
                            expanded:Destroy()
                        end)
                    end)
                end
            end)
            
            break
        end
        
        ProjTPBusy = false
    end)
end

-- Weapon Tracker Logic
local function wtOnShootStart(player)
    wtShootingPlayers[player] = true
    if Config.VoidSpamEnabled and Config.WeaponTrackerEnabled then
        wtVoidActive = true
        task.spawn(function()
            while wtShootingPlayers[player] and wtVoidActive do
                if not player.Character then
                    wtVoidActive = false
                    return
                end
                local char = player.Character
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    hrp.CFrame = CFrame.new(hrp.Position + Vector3.new(0, Config.VoidAltitude, 0))
                end
                task.wait()
            end)
        end
    end
end

local function wtOnShootStop(player)
    task.spawn(function()
        task.wait(Config.ProjLoopDelay / 1000)
        if not Player.Character then return end
        local char = player.Character
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CFrame = wtShootingPlayers[player].RealCF or hrp.CFrame
        end
    end)
    wtShootingPlayers[player] = nil
    wtVoidActive = false
end)

local function wtUnhookPlayer(player)
    if wtConnections[player] then
        for _, conn in pairs(wtConnections[player]) do
            conn:Disconnect()
        end
        wtConnections[player] = nil
    end
    if wtShootingPlayers[player] then
        wtOnShootStop(player)
    end
end

-- Hook weapon tracking
local function setupWeaponTracking()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= lp then
            local char = player.Character
            if char then
                local tool = char:FindFirstChildOfClass("Tool")
                if tool then
                    local activatedConn = tool.Activated:Connect(function()
                        wtOnShootStart(player)
                    end)
                    local deactivatedConn = tool.Deactivated:Connect(function()
                        wtOnShootStop(player)
                    end)
                    
                    if not wtConnections[player] then
                        wtConnections[player] = {}
                    end
                    table.insert(wtConnections[player], activatedConn)
                    table.insert(wtConnections[player], deactivatedConn)
                end
            end
        end
    end
    
    Workspace.ChildAdded:Connect(function(child)
        if child.Name == "CoreProjectile" then
            for player, _ in pairs(wtShootingPlayers) do
                if player.Character then
                    local char = player.Character
                    local hrp = char:FindFirstChild("HumanoidRootPart")
                    local dist = (hrp.Position - child.Position).Magnitude
                    if dist < 30 then
                        wtOnShootStart(player)
                        task.delay(0.5, function()
                            wtOnShootStop(player)
                        end)
                    end
                end
            end
        end
    end)
    
    Players.PlayerRemoving:Connect(function(player)
        wtUnhookPlayer(player)
    end)
    
    lp.CharacterAdded:Connect(function(newChar)
        for player, conns in pairs(wtConnections) do
            wtUnhookPlayer(player)
        end
        wtConnections = {}
        setupWeaponTracking()
    end)
end

