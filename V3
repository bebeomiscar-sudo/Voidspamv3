--[[
    how OmegaBot beats the orbit ragebot in the screenshots:
    
    their setup:
    - void spam + 0.25s hide / 0.1s attack
    - 360 FOV aimbot
    - orbit aura, orbit anti projectile, orbit strike on melee
    - 1 shoot attempt, 0.4s shot interval
    
    ours:
    - 0.08s hide / 0.05s attack = 3x faster cycle
    - ALL enemies hit simultaneously in parallel threads
    - 3+ shoot attempts per target
    - 0.01s shot interval
    - anti projectile sends incoming shots to y=999999
    - melee detection fires projectile TP the moment they swing
    - position prediction leads moving targets
    - dynamic hide time gets shorter as enemies get closer
    - orbit aura pulls ALL enemies to orbit positions around us
    - no FOV limit — we shoot everyone regardless of direction
]]

local function omegaGetHideTime()
    if not Config.OmegaBot.DynamicHide then return Config.OmegaBot.HideTime end
    local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return Config.OmegaBot.HideTime end
    local minDist = math.huge
    for _, player in ipairs(Players:GetPlayers()) do
        if player == lp then continue end
        if not isAlive(player) then continue end
        local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if root then
            local d = (myRoot.Position - root.Position).Magnitude
            if d < minDist then minDist = d end
        end
    end
    -- closer enemy = shorter hide time (minimum DynamicHideMin)
    local t = Config.OmegaBot.HideTime * math.clamp(minDist / 100, 0.3, 1)
    return math.max(t, Config.OmegaBot.DynamicHideMin)
end

local function omegaFireOnEnemy(enemy, proj)
    if not enemy or not enemy.Character then return end
    local hitPartName = Config.ProjectileTP.TargetPart

    local function tryHitbox(name)
        local part = enemy.Character:FindFirstChild(name)
        if not part or not proj then return end
        for _ = 1, Config.OmegaBot.ShootAttempts do
            pcall(function() firetouchinterest(proj, part, 0) end)
            task.wait(Config.OmegaBot.ShootInterval)
            pcall(function() firetouchinterest(proj, part, 1) end)
        end
    end

    tryHitbox(hitPartName)
    tryHitbox("HitBoxHeadSmall")
    tryHitbox("HitBoxHead")
    tryHitbox("Head")

    -- expanded hitbox for good measure
    pcall(function()
        local root = enemy.Character:FindFirstChild("HumanoidRootPart")
        if root and proj then
            local sz  = 12  -- bigger than default 5
            local hb  = Instance.new("Part")
            hb.Name        = "._OmegaHitbox"
            hb.Size        = Vector3.new(sz, sz, sz)
            hb.Anchored    = true
            hb.CanCollide  = false
            hb.Transparency = 1

            -- if prediction is on, lead the target
            if Config.OmegaBot.Prediction then
                local predicted = predictPosition(root, Config.OmegaBot.PredictSteps)
                hb.Position = predicted or root.Position
            else
                hb.Position = root.Position
            end

            hb.Parent = Workspace
            firetouchinterest(proj, hb, 0)
            task.wait(0.01)
            firetouchinterest(proj, hb, 1)
            task.delay(0.5, function() pcall(function() hb:Destroy() end) end)
        end
    end)
end

local function omegaFindProjectile()
    for _, obj in ipairs(Workspace:GetChildren()) do
        if obj.Name == "CoreProjectile" and obj:FindFirstChild("TouchInterest") then
            return obj
        end
    end
    return nil
end

local function omegaApplyOrbitAura(enemies)
    -- pull all enemies to orbit positions around us client-side
    -- this puts them all within firetouchinterest range
    local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end

    local t = tick() * Config.OmegaBot.OrbitSpeed
    for i, enemy in ipairs(enemies) do
        if not enemy.Character then continue end
        local root = enemy.Character:FindFirstChild("HumanoidRootPart")
        if not root then continue end
        pcall(function()
            local angle = t + (i - 1) * (math.pi * 2 / math.max(#enemies, 1))
            local r     = Config.OmegaBot.OrbitRadius
            root.CFrame = CFrame.new(
                myRoot.Position + Vector3.new(math.sin(angle) * r, 0, math.cos(angle) * r)
            )
        end)
    end
end

local function omegaShootAll(enemies)
    local proj = omegaFindProjectile()
    if not proj then return end

    if Config.OmegaBot.MultiThread then
        -- fire at each enemy in its own thread simultaneously
        for _, enemy in ipairs(enemies) do
            task.spawn(function()
                omegaFireOnEnemy(enemy, proj)
            end)
        end
    else
        for _, enemy in ipairs(enemies) do
            omegaFireOnEnemy(enemy, proj)
        end
    end
end

local function startOmegaBot()
    if omegaTask then task.cancel(omegaTask); omegaTask = nil end

    omegaTask = task.spawn(function()
        while Config.OmegaBot.Enabled do
            local char = lp.Character
            if not char then task.wait(0.1); continue end

            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then task.wait(0.1); continue end

            -- save real position
            omegaHrp  = root
            omegaRealCF  = root.CFrame
            omegaRealV   = root.AssemblyLinearVelocity
            omegaRealVA  = root.AssemblyAngularVelocity

            local enemies = getEnemiesSorted({
                TeamCheck  = Config.OmegaBot.TeamCheck,
                Priority   = Config.OmegaBot.Priority,
                MaxDistance = 999,
            })

            if #enemies == 0 then task.wait(0.1); continue end

            -- apply orbit aura (pull enemies to us)
            if Config.OmegaBot.OrbitAura then
                omegaApplyOrbitAura(enemies)
            end

            -- HIDE PHASE: send server to void
            omegaPhase = "hide"
            local hideAlt = Config.OmegaBot.VoidAltitude
            root.CFrame = CFrame.new(
                omegaRealCF.Position.X + math.random(-30, 30),
                hideAlt,
                omegaRealCF.Position.Z + math.random(-30, 30)
            )
            root.AssemblyLinearVelocity  = Vector3.zero
            root.AssemblyAngularVelocity = Vector3.zero

            local hideTime = omegaGetHideTime()
            task.wait(hideTime)

            -- ATTACK PHASE: restore and shoot everyone
            omegaPhase = "attack"
            if omegaHrp and omegaHrp.Parent then
                pcall(function()
                    omegaHrp.CFrame                  = omegaRealCF
                    omegaHrp.AssemblyLinearVelocity  = omegaRealV
                    omegaHrp.AssemblyAngularVelocity = omegaRealVA
                end)
            end

            -- auto shoot tool
            pcall(function()
                local tool = char:FindFirstChildOfClass("Tool")
                if tool then tool:Activate() end
            end)

            task.wait(0.01)
            omegaShootAll(enemies)

            task.wait(Config.OmegaBot.AttackTime)

            if not Config.OmegaBot.Enabled then break end
        end

        omegaTask  = nil
        omegaPhase = "attack"
    end)
end

local function stopOmegaBot()
    Config.OmegaBot.Enabled = false
    if omegaTask then task.cancel(omegaTask); omegaTask = nil end
    omegaPhase = "attack"
    -- restore position
    if omegaHrp and omegaRealCF and omegaHrp.Parent then
        pcall(function()
            omegaHrp.CFrame                  = omegaRealCF
            omegaHrp.AssemblyLinearVelocity  = omegaRealV or Vector3.zero
            omegaHrp.AssemblyAngularVelocity = omegaRealVA or Vector3.zero
        end)
    end
end

-- omegabot melee strike detection
-- watches enemy tool.Activated for melee weapons and fires instantly

local omegaMeleeConnections = {}

local function omegaHookMelee(player)
    if player == lp then return end
    omegaMeleeConnections[player] = omegaMeleeConnections[player] or {}

    local function hookTool(tool)
        -- check if its a melee weapon (no ammo attribute = likely melee)
        local conn = tool.Activated:Connect(function()
            if not Config.OmegaBot.Enabled then return end
            if not Config.OmegaBot.StrikeOnMelee then return end
            if Config.OmegaBot.TeamCheck and sameTeam(player) then return end

            -- fire on them within the melee window
            task.spawn(function()
                local deadline = tick() + Config.OmegaBot.MeleeWindow
                while tick() < deadline and Config.OmegaBot.Enabled do
                    local proj = omegaFindProjectile()
                    if proj then
                        omegaFireOnEnemy(player, proj)
                    end
                    task.wait(0.02)
                end
            end)
        end)
        table.insert(omegaMeleeConnections[player], conn)
    end

    local function watchChar(char)
        for _, child in ipairs(char:GetChildren()) do
            if child:IsA("Tool") then task.spawn(hookTool, child) end
        end
        local c = char.ChildAdded:Connect(function(child)
            if child:IsA("Tool") then task.spawn(hookTool, child) end
        end)
        table.insert(omegaMeleeConnections[player], c)
    end

    if player.Character then task.spawn(watchChar, player.Character) end
    local c = player.CharacterAdded:Connect(function(char)
        for _, conn in ipairs(omegaMeleeConnections[player] or {}) do pcall(function() conn:Disconnect() end) end
        omegaMeleeConnections[player] = {}
        task.spawn(watchChar, char)
    end)
    table.insert(omegaMeleeConnections[player], c)
end

local function startOmegaMeleeHooks()
    for _, p in ipairs(Players:GetPlayers()) do task.spawn(omegaHookMelee, p) end
    Players.PlayerAdded:Connect(function(p) if Config.OmegaBot.Enabled then omegaHookMelee(p) end end)
end

local function setupOmegaPersist()
    if omegaPersistConn then omegaPersistConn:Disconnect() end
    omegaPersistConn = lp.CharacterAdded:Connect(function(char)
        if not Config.OmegaBot.PersistAcrossRounds and not omegaWasEnabled then return end
        if not omegaWasEnabled then return end
        char:WaitForChild("HumanoidRootPart", 10)
        task.wait(1.5)
        if not Config.OmegaBot.Enabled then
            Config.OmegaBot.Enabled = true
            startOmegaBot()
            Library:Notify("OmegaBot resumed after round", 3)
        end
    end)
end

local function enableOmegaBot()
    Config.OmegaBot.Enabled = true
    omegaWasEnabled         = true
    startOmegaBot()
    startOmegaMeleeHooks()
    setupOmegaPersist()
    Library:Notify("OmegaBot enabled — hide:" .. math.floor(Config.OmegaBot.HideTime*1000) .. "ms attack:" .. math.floor(Config.OmegaBot.AttackTime*1000) .. "ms", 4)
end

local function disableOmegaBot()
    omegaWasEnabled = false
    stopOmegaBot()
    for _, player in pairs(omegaMeleeConnections) do
        for _, conn in ipairs(player) do pcall(function() conn:Disconnect() end) end
    end
    omegaMeleeConnections = {}
end

