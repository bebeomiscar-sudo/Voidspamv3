-- PREDICTION
-- leads the target position based on their current velocity
-- so projectile TP connects even when they're moving fast
-- ═══════════════════════════════════════════════════════════════════════

local function predictPosition(root, steps)
    if not root then return nil end
    local ok, pos = pcall(function()
        local vel = root.AssemblyLinearVelocity
        -- extrapolate forward by steps frames at 60fps
        return root.Position + vel * (steps / 60)
    end)
    return ok and pos or root.Position
end

