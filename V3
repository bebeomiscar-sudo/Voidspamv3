-- Utility Functions
local function randomExclude(min, max, deadMin, deadMax)
    min = math.floor(min)
    max = math.floor(max)
    deadMin = math.floor(deadMin)
    deadMax = math.floor(deadMax)
    
    if deadMin <= min and deadMax >= max then
        return max
    end
    
    for i = 1, 500 do
        local val = math.random(min, max)
        if val < deadMin or val > deadMax then
            return val
        end
    end
    return max
end

local function notify(msg)
    Library:Notify(msg, 3)
end

local function getCameraController()
    if CameraController then return CameraController end
    
    local playerScripts = lp:FindFirstChild("PlayerScripts")
    if not playerScripts then return nil end
    
    for _, descendant in ipairs(playerScripts:GetDescendants()) do
        if descendant:IsA("ModuleScript") then
            local name = descendant.Name:lower()
            if name:find("camera") or name == "cameracontroller" then
                local success, module = pcall(function()
                    return require(descendant)
                end)
                if success and module and module.SetRotation then
                    CameraController = module
                    return module
                end
            end
        end
    end
    return CameraController
end

local function getCharacter(player)
    if not player then return nil end
    return player.Character
end

local function getHRP(player)
    local char = getCharacter(player)
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid(player)
    local char = getCharacter(player)
    if not char then return nil end
    return char:FindFirstChildOfClass("Humanoid")
end

local function isTeammate(player)
    if not Config.TeamCheck then return false end
    local myTeam = lp:GetAttribute("TeamID") or lp.Team
    local theirTeam = player:GetAttribute("TeamID") or player.Team
    return myTeam == theirTeam
end

local function isVisible(targetPart)
    if not Config.VisibleCheck then return true end
    if not targetPart then return false end
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {Character, targetPart.Parent}
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    
    local origin = Workspace.CurrentCamera.CFrame.Position
    local direction = (targetPart.Position - origin).Unit * 1000
    
    local result = Workspace:Raycast(origin, direction, raycastParams)
    return result == nil
end

local function getEnemiesSorted()
    local enemies = {}
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= lp and not isTeammate(player) then
            local hrp = getHRP(player)
            local humanoid = getHumanoid(player)
            if hrp and humanoid and humanoid.Health > 0 then
                local distance = (hrp.Position - HRP.Position).Magnitude
                if distance <= Config.MaxFOV then
                    table.insert(enemies, {
                        Player = player,
                        HRP = hrp,
                        Humanoid = humanoid,
                        Distance = distance
                    })
                end
            end
        end
    end
    
    if Config.ProjTargetPriority == "Closest" then
        table.sort(enemies, function(a, b) return a.Distance < b.Distance end)
    elseif Config.ProjTargetPriority == "Furthest" then
        table.sort(enemies, function(a, b) return a.Distance > b.Distance end)
    elseif Config.ProjTargetPriority == "Lowest HP" then
        table.sort(enemies, function(a, b) return a.Humanoid.Health < b.Humanoid.Health end)
    elseif Config.ProjTargetPriority == "Highest HP" then
        table.sort(enemies, function(a, b) return a.Humanoid.Health > b.Humanoid.Health end)
    end
    
    return enemies
end

local function getClosestEnemy()
    local enemies = getEnemiesSorted()
    for _, enemy in ipairs(enemies) do
        if isVisible(enemy.HRP) then
            return enemy
        end
    end
    return nil
end

