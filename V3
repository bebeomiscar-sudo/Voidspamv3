-- ═══════════════════════════════════════════
local watchedHumanoids = {}
local function watchPlayer(p)
    if not p or p == LP then return end
    local function hookChar(char)
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
            or char:WaitForChild("Humanoid", 5)
        if not hum or watchedHumanoids[hum] then return end
        watchedHumanoids[hum] = true
        hum.Died:Connect(function()
            if CFG.KillNotifier then
                CFG.Stats.KillCount = CFG.Stats.KillCount + 1
                Library:Notify("☠ Eliminated " .. p.Name, 3)
                if CFG.KillSound then
                    pcall(function()
                        local snd = Instance.new("Sound", workspace)
                        snd.SoundId            = "rbxassetid://4764109000"
                        snd.Volume             = 0.4
                        snd.RollOffMaxDistance = 0
                        snd:Play()
                        Debris:AddItem(snd, 2)
                    end)
                end
            end
            watchedHumanoids[hum] = nil
        end)
    end
    if p.Character then task.spawn(hookChar, p.Character) end
    p.CharacterAdded:Connect(hookChar)
end
for _, p in ipairs(Players:GetPlayers()) do watchPlayer(p) end
