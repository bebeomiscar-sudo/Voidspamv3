-- ═══════════════════════════════════════════
-- RAGEBOT CORE FIRE
-- Builds cameradata and fires UseItem remote
-- Teleports into target right before firing if WallBang is on
-- ═══════════════════════════════════════════
local function ragebotFire(item, targetPart, targetChar)
    if not item or not targetPart or not targetChar then return end

    local cam      = ws_sa.CurrentCamera.CFrame
    local manip, h = rbCalcPoint(cam.Position, targetPart.Position, targetChar)
    if not manip then return end

    local shootPos = h and cam.Position or manip

    -- Wall bang: teleport into target before the shot
    if CFG.Ragebot.WallBang then
        local eHRP = targetChar:FindFirstChild("HumanoidRootPart")
        wallBangTeleport(eHRP)
    end

    local cameradata = {}
    cameradata[utf8.char(1)] = {
        [utf8.char(0)] = util_mod:EncodeCFrame(
            CFrame.new(shootPos.X, shootPos.Y + (h or 0), shootPos.Z)
            * CFrame.Angles(CFrame.lookAt(shootPos, targetPart.Position):ToOrientation())
        ),
        [utf8.char(1)] = h and
            util_mod:EncodeCFrame(
                CFrame.new(targetPart.Position)
                * CFrame.Angles(CFrame.lookAt(shootPos, targetPart.Position):ToOrientation())
            )
            or util_mod:EncodeCFrame(
                CFrame.new(shootPos.X, shootPos.Y + (h or 0), shootPos.Z)
                * CFrame.Angles(CFrame.lookAt(shootPos, targetPart.Position):ToOrientation())
            ),
        [utf8.char(2)] = targetPart,
        [utf8.char(3)] = util_mod:EncodeCFrame(
            targetPart.CFrame:ToObjectSpace(CFrame.new(targetPart.Position))
        ),
    }

    pcall(function()
        rs_sa.Remotes.Replication.Fighter.UseItem:FireServer(
            item:Get("ObjectID"), enums_mod:ToEnum("StartShooting"), cameradata, nil
        )
    end)

    CFG.Stats.RagebotShots = CFG.Stats.RagebotShots + 1
end

-- ═══════════════════════════════════════════
-- RAGEBOT START / STOP
-- ═══════════════════════════════════════════
local function startRagebot()
    if RagebotState.conn then RagebotState.conn:Disconnect() end
    RagebotState.active        = true
    RagebotState.reloadCooldown = 0

    RagebotState.conn = RunService.Heartbeat:Connect(function(dt)
        if not CFG.Ragebot.On then
            RagebotState.conn:Disconnect()
            RagebotState.conn   = nil
            RagebotState.active = false
            stopWallBang()
            return
        end

        if not LP.Character then return end
        if not LP.Character:FindFirstChild("HumanoidRootPart") then return end
        if not fighter_mod or not fighter_mod.LocalFighter then return end

        local item = fighter_mod.LocalFighter.EquippedItem
        if not item then return end

        -- Auto reload check
        if CFG.Ragebot.AutoReload then
            RagebotState.reloadCooldown = RagebotState.reloadCooldown - dt
            local currentAmmo = nil
            pcall(function() currentAmmo = item:Get("CurrentAmmo") end)
            if currentAmmo ~= nil and currentAmmo <= 0 and RagebotState.reloadCooldown <= 0 then
                tryRagebotReload(item)
                RagebotState.reloadCooldown = 2.0
                return
            end
        end

        -- Find target and fire
        local targetPart, targetChar = rbGetClosest()
        if not targetPart or not targetChar then
            RagebotState.currentTarget = nil
            return
        end

        RagebotState.currentTarget = targetChar
        ragebotFire(item, targetPart, targetChar)
    end)
end

local function stopRagebot()
    CFG.Ragebot.On = false
    if RagebotState.conn then
        RagebotState.conn:Disconnect()
        RagebotState.conn = nil
    end
    RagebotState.active        = false
    RagebotState.currentTarget = nil
    stopWallBang()
end

