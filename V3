-- ═══════════════════════════════════════════
LP.CharacterAdded:Connect(function(nc)
    character        = nc
    humanoidRootPart = nc:WaitForChild("HumanoidRootPart")
    humanoid         = nc:WaitForChild("Humanoid")

    VoidState.InFlicker       = false
    VoidState.EvadeCooldown   = 0
    VoidState.DesyncTimer     = 0
    VoidState.CorrectionCount = 0

    -- Reset ragebot state
    RagebotState.currentTarget = nil
    RagebotState.wbActive      = false
    RagebotState.wbOrigPos     = nil
    if RagebotState.wbConn then
        RagebotState.wbConn:Disconnect()
        RagebotState.wbConn = nil
    end

    task.wait(1.5)

    for _, p in ipairs(Players:GetPlayers()) do watchPlayer(p) end

    if CFG.Void.On    then startVoid()    end
    if CFG.Ragebot.On then startRagebot() end
end)

