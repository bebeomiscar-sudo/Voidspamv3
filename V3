    ["Random"]       = { "Random" },
}

local TARGET_OPTIONS = {
    "Head", "HumanoidRootPart", "Torso", "UpperTorso",
    "LowerTorso", "Body", "Head, Body", "Random",
}

local function getBestPart(char, setting)
    local preset = PART_PRESETS[setting] or { "Head" }
    if preset[1] == "Random" then
        local available = {}
        for _, pn in ipairs(ALL_PARTS) do
            local p = char:FindFirstChild(pn)
            if p then table.insert(available, p) end
        end
        return #available > 0 and available[math.random(#available)] or nil
    end
    for _, pn in ipairs(preset) do
        local p = char:FindFirstChild(pn)
        if p then return p end
    end
    for _, pn in ipairs(ALL_PARTS) do
        local p = char:FindFirstChild(pn)
        if p then return p end
    end
    return nil
end

-- enemy sorting

local function getEnemiesSorted()
    local list   = {}
    local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")

    for _, player in ipairs(Players:GetPlayers()) do
        if player == lp then continue end
        if not isAlive(player) then continue end
        if Config.ProjectileTP.TeamCheck and sameTeam(player) then continue end

        local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if root and myRoot then
            local dist = (myRoot.Position - root.Position).Magnitude
            if dist > Config.ProjectileTP.MaxDistance then continue end
            if Config.ProjectileTP.VisCheck and not visibleFrom(myRoot.Position, root) then continue end
            table.insert(list, { player = player, dist = dist })
        end
    end

    local p = Config.ProjectileTP.Priority
    if p == "Closest" then
        table.sort(list, function(a, b) return a.dist < b.dist end)
    elseif p == "Furthest" then
        table.sort(list, function(a, b) return a.dist > b.dist end)
    elseif p == "Random" then
        for i = #list, 2, -1 do
            local j = math.random(i)
            list[i], list[j] = list[j], list[i]
        end
    elseif p == "Lowest HP" then
        table.sort(list, function(a, b)
            local ha = a.player.Character:FindFirstChildOfClass("Humanoid")
            local hb = b.player.Character:FindFirstChildOfClass("Humanoid")
            return (ha and ha.Health or 0) < (hb and hb.Health or 0)
        end)
    elseif p == "Highest HP" then
        table.sort(list, function(a, b)
            local ha = a.player.Character:FindFirstChildOfClass("Humanoid")
            local hb = b.player.Character:FindFirstChildOfClass("Humanoid")
            return (ha and ha.Health or 0) > (hb and hb.Health or 0)
        end)
    end

    local out = {}
    for _, e in ipairs(list) do table.insert(out, e.player) end
    return out
end

local function getClosestEnemy()
    return getEnemiesSorted()[1]
end

local function cacheEnemies()
    EnemyCache = getEnemiesSorted()
end

-- aimbot

local function aimbotFOV()
    local f = Config.Aimbot.MaxFOV
    if Config.Aimbot.DynamicFOV then f = f * (camera.FieldOfView / 70) end
    return f
end

local function inFOV(part)
    if not part then return false end
    local sp, onScreen = camera:WorldToViewportPoint(part.Position)
    if not onScreen then return false end
    return (Vector2.new(sp.X, sp.Y) - screenCenter()).Magnitude <= aimbotFOV()
end

local function resetDelayed()
    delayedTargetPos = nil
end

local function getDelayedPos(part, dt)
    if not part or not part.Parent then
        delayedTargetPos = nil
        return nil
    end

    local real = part.Position
    if not delayedTargetPos then
        delayedTargetPos = real
        return real
    end

    local jumping = false
    pcall(function()
        local r = part.Parent:FindFirstChild("HumanoidRootPart")
        if r then jumping = r.AssemblyLinearVelocity.Y > 2 end
    end)

    local bf = 60 * dt
    local xA = math.clamp((1 - Config.Aimbot.XSmooth) * (1 + bf), 0.01, 1)
    local yA = (jumping and Config.Aimbot.JumpSmooth > 0)
        and math.clamp((1 - Config.Aimbot.JumpSmooth) * (1 + bf), 0.01, 1)
        or  math.clamp((1 - Config.Aimbot.YSmooth)    * (1 + bf), 0.01, 1)

    delayedTargetPos = Vector3.new(
        delayedTargetPos.X + (real.X - delayedTargetPos.X) * xA,
        delayedTargetPos.Y + (real.Y - delayedTargetPos.Y) * yA,
        delayedTargetPos.Z + (real.Z - delayedTargetPos.Z) * xA
    )
    return delayedTargetPos
end

--[[
    check if a character belongs to a real player
    this stops the aimbot from locking onto things like:
    - workspace.Target (the red target in shooting range)
    - dummy characters that arent in ShootingRangeEntities
    - any other NPC-style model
]]
local function isPlayerCharacter(char)
    if not char then return false end
    -- must be owned by a real Players instance
    return Players:GetPlayerFromCharacter(char) ~= nil
end

--[[
    check if a part is inside a dummy from ShootingRangeEntities
    used by track dummy only — not by the normal aimbot
]]
local function isDummyPart(part)
    if not part then return false end
    local entities = Workspace:FindFirstChild("ShootingRangeEntities")
    if not entities then return false end
    -- walk up the hierarchy and see if we end up inside ShootingRangeEntities
    local ancestor = part.Parent
    while ancestor do
        if ancestor == entities then return true end
        ancestor = ancestor.Parent
    end
    return false
end

local function targetStillValid(part)
    if not part or not part.Parent then return false end

    -- never lock onto the red Target instance or anything that isnt a real player
    if not isPlayerCharacter(part.Parent) then return false end

    local hum = part.Parent:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if not inFOV(part) then return false end
    if Config.Aimbot.VisibleCheck and not visibleFrom(camera.CFrame.Position, part) then return false end
    if Config.Aimbot.TeamCheck then
        local p = Players:GetPlayerFromCharacter(part.Parent)
        if p and sameTeam(p) then return false end
    end
    return true
end

local function findTarget()
    local c    = screenCenter()
    local eFOV = aimbotFOV()
    local best, bestDist = nil, eFOV

    for _, player in ipairs(Players:GetPlayers()) do
        if player == lp then continue end
        if Config.Aimbot.TeamCheck and sameTeam(player) then continue end

        local ch = player.Character
        if not ch then continue end

        -- skip if no humanoid or dead
        local hum = ch:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end

        -- only lock real player characters, not Target/NPCs
        if not isPlayerCharacter(ch) then continue end

        local part = getBestPart(ch, Config.Aimbot.TargetPart)
        if not part then continue end

        local sp, onScreen = camera:WorldToScreenPoint(part.Position)
        if not onScreen then continue end

        local dist = (Vector2.new(sp.X, sp.Y) - c).Magnitude
        if dist > eFOV then continue end

        if Config.Aimbot.VisibleCheck and not visibleFrom(camera.CFrame.Position, part) then continue end

        if dist < bestDist then
            bestDist = dist
            best     = part
        end
    end

    return best
end

-- dummy tracking

--[[
    get the dummy at the configured index from ShootingRangeEntities
    we specifically look inside ShootingRangeEntities so we never
    accidentally grab a player or the red Target model
]]
local function getDummyPart()
    local entities = Workspace:FindFirstChild("ShootingRangeEntities")
    if not entities then return nil end

    local children = entities:GetChildren()
    if #children == 0 then return nil end

    local idx   = math.clamp(Config.TrackDummy.DummyIndex, 1, #children)
    local dummy = children[idx]
    if not dummy then return nil end

    -- make sure we're grabbing from the right thing
    -- dummies are Models inside ShootingRangeEntities
    -- the red Target is a separate BasePart directly in workspace, not here
    return getBestPart(dummy, Config.Aimbot.TargetPart)
        or dummy:FindFirstChild("HumanoidRootPart")
        or dummy:FindFirstChildOfClass("BasePart")
end

-- rotate camera toward a world position

local function rotateTo(pos, smoothness)
    if not CameraController then return end
    pcall(function()
        local cp  = camera.CFrame.Position
        local dir = (pos - cp).Unit
        local tP  = math.asin(math.clamp(dir.Y, -1, 1))
        local tY  = math.atan2(-dir.X, -dir.Z)
        local sm  = math.clamp(1 / math.max(smoothness or Config.Aimbot.Smoothness, 0.1), 0.01, 1)
        local cur = CameraController.Rotation
        CameraController:SetRotation(Vector2.new(
            cur.X + (tP - cur.X) * sm,
            cur.Y + angleDiff(cur.Y, tY) * sm
        ))
    end)
end

local function runAimbot(dt)
    if not Config.Aimbot.Enabled and not Config.TrackDummy.Enabled then return end

    if fovCircle then
        fovCircle.Position = screenCenter()
        fovCircle.Radius   = aimbotFOV()
        fovCircle.Visible  = Config.Aimbot.DrawFOV
            and Config.Aimbot.FOVStyle ~= "Invisible"
            and (Config.Aimbot.Enabled or Config.TrackDummy.Enabled)
    end

    if not CameraController then return end

    -- track dummy takes priority, completely separate from normal aimbot
    if Config.TrackDummy.Enabled then
        local part = getDummyPart()
        if part then rotateTo(part.Position) end
        return
    end

    if not Config.Aimbot.Enabled then return end

    -- reaction delay
    if isInReaction then
        reactionTimer -= dt
        if reactionTimer <= 0 then isInReaction = false end
        return
    end

    -- drop target if no longer valid
    if lockedTarget and not targetStillValid(lockedTarget) then
        lockedTarget = nil
        lockTimer    = 0
        resetDelayed()
    end

    -- find a new target if we dont have one
    if not lockedTarget then
        local t = findTarget()
        if t then
            lockedTarget  = t
            lockTimer     = 0
            isInReaction  = true
            reactionTimer = Config.Aimbot.ReactionTime / 1000
            resetDelayed()
        end
        return
    end

    -- forget timer
    lockTimer += dt
    if lockTimer > Config.Aimbot.ForgotTime then
        lockedTarget = nil
        lockTimer    = 0
        resetDelayed()
        return
    end

    if inFOV(lockedTarget) then
        local aimPos = getDelayedPos(lockedTarget, dt)
        if aimPos then rotateTo(aimPos) end
    else
        lockedTarget = nil
        lockTimer    = 0
        resetDelayed()
    end
end

-- sound spam

local function playSoundOnce(soundId, volume)
    pcall(function()
        local part = Instance.new("Part")
        part.Anchored     = true
        part.CanCollide   = false
        part.Transparency = 1
        part.Size         = Vector3.one

        local char = lp.Character
        if char then
            local root = char:FindFirstChild("HumanoidRootPart")
            part.Position = root and root.Position or Vector3.zero
        end
        part.Parent = Workspace

        local snd = Instance.new("Sound")
        snd.SoundId             = soundId
        snd.Volume              = volume or 1
        snd.RollOffMaxDistance  = 10000
        snd.Parent              = part
        snd:Play()

        task.delay(5, function()
            pcall(function() part:Destroy() end)
        end)
    end)
end

local function startSoundSpam()
    if soundSpamTask then task.cancel(soundSpamTask) end
    soundSpamTask = task.spawn(function()
        while Config.SoundSpam.Enabled do
            local id = Config.SoundSpam.CustomId ~= "" and Config.SoundSpam.CustomId or Config.SoundSpam.SoundId
            playSoundOnce(id, Config.SoundSpam.Volume)
            task.wait(math.max(0.01, Config.SoundSpam.Interval))
        end
        soundSpamTask = nil
    end)
end

local function stopSoundSpam()
    Config.SoundSpam.Enabled = false
    if soundSpamTask then task.cancel(soundSpamTask); soundSpamTask = nil end
end

