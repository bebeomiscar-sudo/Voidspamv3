-- ═══════════════════════════════════════════
-- FRACTAL DRIFT DIRECTION
-- ═══════════════════════════════════════════
local function computeDriftDir(t)
    local nx, nz, amp, freq = 0, 0, 1, 0.0001
    for _ = 1, 4 do
        nx   = nx + math.noise(t * freq, 0) * amp
        nz   = nz + math.noise(0, t * freq) * amp
        freq = freq * 2.37
        amp  = amp  * 0.5
    end
    local sp = t * 0.00073
    nx = nx + math.noise(sp + 13.7, 7.3)  * 0.3
    nz = nz + math.noise(sp + 31.1, 17.9) * 0.3
    local cp = t * 0.00213
    nx = nx + math.sin(cp) * math.cos(cp * 1.618) * 0.2
    nz = nz + math.cos(cp * 0.618) * math.sin(cp * 2.718) * 0.2
    local len = math.sqrt(nx * nx + nz * nz)
    if len < 0.001 then
        local a = t * math.pi * 0.1
        return math.cos(a), math.sin(a)
    end
    return nx / len, nz / len
end

-- ═══════════════════════════════════════════
-- VOID POSITION COMPUTATION — all 33 methods
-- ═══════════════════════════════════════════
local function computeVoidPosition(dt)
    local t  = VoidState.Elapsed
    local bY = CFG.Void.YBase + VoidState.YOffset
    local m  = CFG.Void.Method

    if m == "Stable" then
        return Vector3.new(VoidState.X, bY, VoidState.Z)

    elseif m == "Drift" then
        local dx, dz = computeDriftDir(t)
        VoidState.DirX    = VoidState.DirX + (dx - VoidState.DirX) * CFG.Void.DriftChaos * dt * 10
        VoidState.DirZ    = VoidState.DirZ + (dz - VoidState.DirZ) * CFG.Void.DriftChaos * dt * 10
        VoidState.X       = VoidState.X + VoidState.DirX * CFG.Void.DriftSpeed * dt
        VoidState.Z       = VoidState.Z + VoidState.DirZ * CFG.Void.DriftSpeed * dt
        VoidState.YOffset = VoidState.YOffset + VoidState.YDir * CFG.Void.YDriftSpeed * dt
        if math.abs(VoidState.YOffset) >= CFG.Void.YDriftRange then
            VoidState.YDir = -VoidState.YDir
        end
        return Vector3.new(VoidState.X, CFG.Void.YBase + VoidState.YOffset, VoidState.Z)

    elseif m == "Chaotic" then
        VoidState.X       = VoidState.X + (math.random()-0.5) * CFG.Void.DriftSpeed * dt * 5
        VoidState.Z       = VoidState.Z + (math.random()-0.5) * CFG.Void.DriftSpeed * dt * 5
        VoidState.YOffset = VoidState.YOffset + (math.random()-0.5) * CFG.Void.YDriftSpeed * dt * 5
        return Vector3.new(VoidState.X, CFG.Void.YBase + VoidState.YOffset, VoidState.Z)

    elseif m == "Circle" then
        local r = 1e9
        return Vector3.new(VoidState.X+math.cos(t*2)*r, bY, VoidState.Z+math.sin(t*2)*r)

    elseif m == "Spiral" then
        local r = 1e9 * (1 + math.sin(t))
        return Vector3.new(VoidState.X+math.cos(t*3)*r, bY, VoidState.Z+math.sin(t*3)*r)

    elseif m == "Lissajous" then
        local r = 2e9
        return Vector3.new(
            VoidState.X + math.sin(t*CFG.LissajousA)*r, bY,
            VoidState.Z + math.sin(t*CFG.LissajousB)*r
        )

    elseif m == "Perlin Noise" then
        local nt = t * 0.1
        return Vector3.new(
            VoidState.X + math.noise(nt,0)*5e9, bY,
            VoidState.Z + math.noise(0,nt)*5e9
        )

    elseif m == "Flicker" then
        local flip = (tick() % (CFG.FlickerInterval*2) < CFG.FlickerInterval)
        return flip
            and Vector3.new(VoidState.X, CFG.Void.YBase, VoidState.Z)
            or  Vector3.new(-VoidState.X, CFG.Void.YBase+1e9, -VoidState.Z)

    elseif m == "Gravity Well" then
        local gt = t * 0.5; local r = CFG.GravityStr * (1 + math.sin(gt))
        return Vector3.new(
            VoidState.X + math.cos(gt)*r,
            bY + math.sin(gt*0.7)*r,
            VoidState.Z + math.sin(gt)*r
        )

    elseif m == "Helix" then
        local r = 1e9; local ht = t * 2
        return Vector3.new(
            VoidState.X + math.cos(ht)*r,
            bY + math.sin(ht*0.5)*r,
            VoidState.Z + math.sin(ht)*r
        )

    elseif m == "Figure 8" then
        local r = 1.5e9; local ft = t * 1.5
        return Vector3.new(
            VoidState.X + math.sin(ft)*r, bY,
            VoidState.Z + math.sin(ft)*math.cos(ft)*r
        )

    elseif m == "Tornado" then
        local r = 2e9 * math.abs(math.sin(t)); local tt = t * 5
        return Vector3.new(
            VoidState.X + math.cos(tt)*r,
            bY + math.sin(t*2)*1e9,
            VoidState.Z + math.sin(tt)*r
        )

    elseif m == "Butterfly" then
        local r = (math.exp(math.sin(t)) - 2*math.cos(4*t) + math.sin((2*t-math.pi)/24)^5) * 5e8
        return Vector3.new(
            VoidState.X + math.sin(t)*r,
            bY + math.cos(t)*r,
            VoidState.Z + math.sin(t*0.5)*r
        )

    elseif m == "Double Helix" then
        local r = 1e9; local dht = t*3
        local off = (tick()%1 < 0.5) and 1 or -1
        return Vector3.new(
            VoidState.X + math.cos(dht)*r*off,
            bY + math.sin(dht)*5e8,
            VoidState.Z + math.sin(dht)*r*off
        )

    elseif m == "Chaotic Sphere" then
        local r = 2e9; local t1 = t*2; local t2 = t*1.3
        return Vector3.new(
            VoidState.X + math.sin(t1)*math.cos(t2)*r,
            bY + math.sin(t1)*math.sin(t2)*r,
            VoidState.Z + math.cos(t1)*r
        )

    elseif m == "Quantum Tunneling" then
        local r = 1e11 * randSign()
        local j = Vector3.new(
            (math.random()-0.5)*2e9,
            (math.random()-0.5)*2e8,
            (math.random()-0.5)*2e9
        )
        return Vector3.new(VoidState.X+r, bY+j.Y, VoidState.Z+r) + j

    elseif m == "Fractal Desync" then
        local ft = t*5
        local x = math.sin(ft) + math.sin(ft*2.1)/2 + math.sin(ft*3.2)/4
        local z = math.cos(ft) + math.cos(ft*2.2)/2 + math.cos(ft*3.1)/4
        return Vector3.new(
            VoidState.X + x*1e10,
            bY + math.sin(ft*10)*1e9,
            VoidState.Z + z*1e10
        )

    elseif m == "Extreme Desync" then
        local et = t*15; local r = 1e12
        return Vector3.new(
            VoidState.X + math.sin(et)*r,
            bY + math.cos(et*1.5)*r*0.1,
            VoidState.Z + math.cos(et)*r
        )

    elseif m == "Quantum Oscillation" then
        local qt = t*50; local r = 1e11*math.sin(qt)
        return Vector3.new(VoidState.X+r, bY+math.cos(qt)*1e10, VoidState.Z+r)

    elseif m == "Frame Skip" then
        if tick()%0.1 < 0.05 then
            return Vector3.new(VoidState.X*2, bY+1e11, VoidState.Z*2)
        end
        return Vector3.new(VoidState.X, bY, VoidState.Z)

    elseif m == "Seizure" then
        VoidState.SeizureTimer = VoidState.SeizureTimer + dt * CFG.SeizureSpeed
        if VoidState.SeizureTimer >= 1 then
            VoidState.SeizureTimer = VoidState.SeizureTimer - 1
            VoidState.SeizureIndex = VoidState.SeizureIndex + 1
            if VoidState.SeizureIndex > #VoidState.SeizurePool then
                VoidState.SeizureIndex = 1
                refreshSeizurePool()
            end
        end
        local idx = clamp(VoidState.SeizureIndex, 1, #VoidState.SeizurePool)
        return VoidState.SeizurePool[idx]

    elseif m == "Hyperdrive" then
        local dx, dz = computeDriftDir(t)
        local hyper  = CFG.HyperdriveSpeed * 1e8
        VoidState.DirX    = VoidState.DirX + (dx - VoidState.DirX) * 0.9 * dt * 20
        VoidState.DirZ    = VoidState.DirZ + (dz - VoidState.DirZ) * 0.9 * dt * 20
        VoidState.X       = VoidState.X + VoidState.DirX * hyper * dt
        VoidState.Z       = VoidState.Z + VoidState.DirZ * hyper * dt
        VoidState.YOffset = VoidState.YOffset + math.sin(t*7.3) * CFG.Void.YDriftSpeed * dt * 3
        return Vector3.new(VoidState.X, CFG.Void.YBase + VoidState.YOffset, VoidState.Z)

    elseif m == "Schrodinger" then
        local phaseA = Vector3.new(
            VoidState.X + math.sin(t*3.7)*5e11,
            bY + math.cos(t*2.1)*1e10,
            VoidState.Z + math.cos(t*3.7)*5e11
        )
        local phaseB = Vector3.new(
            VoidState.X - math.cos(t*5.3)*5e11,
            bY - math.sin(t*4.9)*1e10,
            VoidState.Z + math.sin(t*5.3)*5e11
        )
        return (tick()%0.016 < 0.008) and phaseA or phaseB

    elseif m == "Glitch Storm" then
        local primes = {2,3,5,7,11,13,17,19}
        local gx, gy, gz = 0, 0, 0
        for i = 1, math.min(CFG.GlitchLayers, 8) do
            local p   = primes[i]
            local amp = 1e11 / i
            gx = gx + math.sin(t * p * 1.7) * amp
            gy = gy + math.cos(t * p * 2.3) * amp * 0.1
            gz = gz + math.cos(t * p * 1.3) * amp
        end
        gx = gx + (math.random()-0.5) * 2e10
        gz = gz + (math.random()-0.5) * 2e10
        return Vector3.new(VoidState.X+gx, CFG.Void.YBase+gy, VoidState.Z+gz)

    elseif m == "Dimensional Rift" then
        local k     = CFG.RiftPhase
        local rMax  = 1e12
        local theta = t * (1 + k * 0.1)
        local r     = rMax * math.abs(math.cos(k * theta))
        local plane = math.floor(t * k) % k
        local pAngle= (plane / k) * math.pi * 2
        local fAngle= theta + pAngle
        local planeY= math.sin(t * k + plane * math.pi * 2 / k) * 1e11
        return Vector3.new(
            VoidState.X + math.cos(fAngle) * r,
            CFG.Void.YBase + planeY,
            VoidState.Z + math.sin(fAngle) * r
        )

    elseif m == "Wormhole" then
        VoidState.WormholePhase = VoidState.WormholePhase + dt * 12
        local count     = CFG.WormholeCount
        local exitIdx   = math.floor(VoidState.WormholePhase) % count
        local exitAngle = (exitIdx / count) * math.pi * 2
        local exitR     = 1e11
        local exitY     = bY + math.sin(exitAngle*2+t) * 2e10
        local sectorOsc = math.sin(VoidState.WormholePhase * math.pi) * 5e9
        return Vector3.new(
            VoidState.X + math.cos(exitAngle) * (exitR + sectorOsc),
            exitY,
            VoidState.Z + math.sin(exitAngle) * (exitR + sectorOsc)
        )

    elseif m == "Phantom" then
        VoidState.PhantomPhase = VoidState.PhantomPhase + dt * 30
        local layers  = CFG.PhantomLayers
        local layer   = math.floor(VoidState.PhantomPhase) % layers
        local layerT  = t + (layer / layers) * math.pi * 2
        local baseR   = 3e11
        local baseX   = VoidState.X + math.sin(layerT * 1.3) * baseR
        local baseZ   = VoidState.Z + math.cos(layerT * 0.9) * baseR
        local baseY   = bY + math.cos(layerT * 2.1) * 5e10
        local perpX   = math.cos(layerT + layer) * 8e10 * (layer + 1)
        local perpZ   = math.sin(layerT + layer) * 8e10 * (layer + 1)
        return Vector3.new(baseX + perpX, baseY, baseZ + perpZ)

    elseif m == "Supernova" then
        VoidState.NovaTimer = VoidState.NovaTimer + dt
        if not VoidState.NovaActive then
            local qt = t * 40; local r = 5e9 * math.abs(math.sin(qt))
            if VoidState.NovaTimer > 2.5 then
                VoidState.NovaActive = true
                VoidState.NovaTimer  = 0
                VoidState.NovaPos    = Vector3.new(
                    VoidState.X + (math.random()-0.5) * 1e12,
                    bY + (math.random()-0.5) * 1e11,
                    VoidState.Z + (math.random()-0.5) * 1e12
                )
            end
            return Vector3.new(
                VoidState.X + math.cos(qt)*r,
                bY + math.sin(qt*0.7)*r*0.1,
                VoidState.Z + math.sin(qt)*r
            )
        else
            if VoidState.NovaTimer > 0.8 then
                VoidState.NovaActive = false
                VoidState.NovaTimer  = 0
            end
            return VoidState.NovaPos
        end

    elseif m == "Mirror" then
        local flip = (tick() % (CFG.FlickerInterval*2) < CFG.FlickerInterval)
        local basePos = Vector3.new(
            VoidState.X + math.sin(t*0.7)*2e10,
            bY + math.cos(t*0.5)*5e9,
            VoidState.Z + math.cos(t*0.7)*2e10
        )
        if flip then return basePos end
        if CFG.MirrorAxes then
            return Vector3.new(-basePos.X, CFG.Void.YBase*2 - basePos.Y, -basePos.Z)
        else
            if math.abs(basePos.X) > math.abs(basePos.Z) then
                return Vector3.new(-basePos.X, basePos.Y, basePos.Z)
            else
                return Vector3.new(basePos.X, basePos.Y, -basePos.Z)
            end
        end

    elseif m == "Pulse Wave" then
        local pFreq  = CFG.PulseWaveFreq
        local pPhase = t * pFreq * math.pi * 2
        local pR     = 1e12 * math.abs(math.sin(pPhase))
        local pAngle = t * 3.7
        local pY     = math.sin(pPhase * 1.3) * 5e10
        return Vector3.new(
            VoidState.X + math.cos(pAngle) * pR,
            bY + pY,
            VoidState.Z + math.sin(pAngle) * pR
        )

    elseif m == "Echo" then
        local currentBase = Vector3.new(
            VoidState.X + math.sin(t*2.1)*1e10,
            bY + math.cos(t*1.7)*5e9,
            VoidState.Z + math.cos(t*2.1)*1e10
        )
        VoidState.EchoHistory[VoidState.EchoIndex] = currentBase
        VoidState.EchoIndex = (VoidState.EchoIndex % #VoidState.EchoHistory) + 1
        local delayFrames = math.floor(CFG.EchoDelay * 60)
        local readIdx = ((VoidState.EchoIndex - delayFrames - 1) % #VoidState.EchoHistory) + 1
        return VoidState.EchoHistory[readIdx] or currentBase

    elseif m == "Singularity" then
        local cPhase = math.sin(t * CFG.CollapseSpeed)
        local cNorm  = (cPhase + 1) * 0.5
        local cR     = lerp(1e8, 1e12, cNorm)
        local dAngle = t * 2.3
        local dY     = math.sin(t * 1.7 + math.pi * 0.5)
        return Vector3.new(
            VoidState.X + math.cos(dAngle) * cR,
            bY + dY * cR * 0.1,
            VoidState.Z + math.sin(dAngle) * cR
        )

    elseif m == "Storm Cell" then
        local cellCount  = 5
        local cellPeriod = 0.12
        local cellIdx    = math.floor(t / cellPeriod) % cellCount
        local speeds     = {1.3, 2.7, 4.1, 6.3, 9.7}
        local radii      = {0.3, 0.55, 0.7, 0.85, 1.0}
        local yFreqs     = {1.1, 1.9, 2.7, 3.3, 5.1}
        local spd        = speeds[cellIdx + 1]
        local rad        = CFG.StormRadius * radii[cellIdx + 1]
        local yF         = yFreqs[cellIdx + 1]
        local cAngle     = t * spd + cellIdx * (math.pi * 2 / cellCount)
        local cY         = bY + math.sin(t * yF) * 2e10
        return Vector3.new(
            VoidState.X + math.cos(cAngle) * rad,
            cY,
            VoidState.Z + math.sin(cAngle) * rad
        )
    end

    return Vector3.new(VoidState.X, bY, VoidState.Z)
end

-- ═══════════════════════════════════════════
-- BYPASS ENGINE v3
-- ═══════════════════════════════════════════
local function detectCorrection(hrp, targetPos)
    if not hrp then return false end
    local diff = (hrp.Position - VoidState.LastWrittenPos).Magnitude
    return diff > 1e8 and diff < (targetPos - VoidState.LastWrittenPos).Magnitude
end

local function writeCFrame(hrp, pos)
    pcall(function() hrp.CFrame = CFrame.new(pos) end)
    VoidState.LastWrittenPos = pos
end

local function applyMomentum(hrp, targetPos, dt)
    if not hrp then return end
    local toTarget = targetPos - hrp.Position
    VoidState.Momentum = VoidState.Momentum * CFG.Bypass.MomentumDecay
        + toTarget * (1 - CFG.Bypass.MomentumDecay)
    pcall(function() hrp.AssemblyLinearVelocity = VoidState.Momentum / dt end)
end

local function maybePulse(hrp)
    if not CFG.Bypass.NetworkPulse then return end
    if math.random(1, CFG.Bypass.PulseRate) == 1 then
        pcall(function()
            local s = CFG.Bypass.PulseStrength
            hrp.AssemblyLinearVelocity = Vector3.new(
                (math.random()-0.5)*2*s,
                (math.random()-0.5)*2*s,
                (math.random()-0.5)*2*s
            )
        end)
    end
end

local function maybeAntiCorrect(hrp, targetPos)
    if not CFG.Bypass.AntiCorrect then return end
    if detectCorrection(hrp, targetPos) then
        VoidState.CorrectionCount = VoidState.CorrectionCount + 1
        pcall(function()
            local pushDir = targetPos - hrp.Position
            if pushDir.Magnitude > 0 then
                hrp.AssemblyLinearVelocity = pushDir.Unit
                    * CFG.Bypass.PulseStrength * CFG.Bypass.AntiCorrectStr
            end
        end)
    end
end

local function addJitter(pos)
    if not CFG.Bypass.Jitter then return pos end
    local s = CFG.Bypass.JitterScale
    return pos + Vector3.new(
        (math.random()-0.5)*2*s,
        (math.random()-0.5)*2*s,
        (math.random()-0.5)*2*s
    )
end

local function selectAdaptiveMode()
    local m = CFG.Void.Method
    local cleanMethods = {
        Stable=true, Circle=true, Spiral=true, Lissajous=true,
        Helix=true, ["Figure 8"]=true, ["Double Helix"]=true,
        ["Chaotic Sphere"]=true, ["Pulse Wave"]=true,
        Echo=true, Singularity=true, ["Storm Cell"]=true,
    }
    local chaosMethods = {
        ["Quantum Tunneling"]=true, ["Fractal Desync"]=true,
        ["Extreme Desync"]=true, ["Quantum Oscillation"]=true,
        ["Frame Skip"]=true, Seizure=true, Wormhole=true,
        Phantom=true, Supernova=true,
    }
    local hybridMethods = {
        Drift=true, Chaotic=true, Tornado=true, Butterfly=true,
        Hyperdrive=true, ["Glitch Storm"]=true, ["Dimensional Rift"]=true,
        ["Storm Cell"]=true,
    }
    local multiMethods = {
        Schrodinger=true, Mirror=true, Flicker=true,
        Seizure=true, Phantom=true,
    }
    if multiMethods[m]  then return "Multi-Write"      end
    if chaosMethods[m]  then return "Physics Chaos"    end
    if hybridMethods[m] then return "Hybrid"           end
    if cleanMethods[m]  then return "Clean CFrame"     end
    return "Extreme Networking"
end

local function applyBypass(hrp, targetPos, dt)
    if not hrp then return end
    local mode = CFG.Bypass.Mode
    if mode == "Adaptive" then
        VoidState.AdaptiveTimer = VoidState.AdaptiveTimer + dt
        if VoidState.AdaptiveTimer > (1 - CFG.Bypass.AdaptiveSensitivity) * 2 then
            VoidState.AdaptiveTimer = 0
            local newMode = selectAdaptiveMode()
            if newMode ~= VoidState.AdaptiveMode then
                VoidState.AdaptiveMode    = newMode
                CFG.Stats.BypassSwitches  = CFG.Stats.BypassSwitches + 1
            end
        end
        mode = VoidState.AdaptiveMode
    end

    local writePos = (mode ~= "Clean CFrame" and mode ~= "Multi-Write")
        and addJitter(targetPos) or targetPos

    if mode == "Clean CFrame" then
        writeCFrame(hrp, writePos)
        pcall(function()
            hrp.AssemblyLinearVelocity  = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
        end)
        maybeAntiCorrect(hrp, targetPos)

    elseif mode == "Velocity" then
        pcall(function()
            hrp.AssemblyLinearVelocity = (targetPos - hrp.Position) * 120
        end)

    elseif mode == "Hybrid" then
        writeCFrame(hrp, writePos)
        pcall(function()
            hrp.AssemblyLinearVelocity = Vector3.new(
                (math.random()-0.5)*100, 0.01, (math.random()-0.5)*100
            )
        end)
        maybeAntiCorrect(hrp, targetPos)

    elseif mode == "Physics Chaos" then
        writeCFrame(hrp, writePos)
        pcall(function()
            local s = CFG.Bypass.PulseStrength
            hrp.AssemblyLinearVelocity = Vector3.new(
                (math.random()-0.5)*2*s,
                (math.random()-0.5)*2*s,
                (math.random()-0.5)*2*s
            )
        end)

    elseif mode == "Multi-Write" then
        local count = CFG.Bypass.MultiWriteCount
        for i = 1, count do
            local subOffset = Vector3.new(
                math.sin(i*1.3)*10, math.sin(i*2.1)*5, math.cos(i*1.7)*10
            )
            writeCFrame(hrp, writePos + subOffset)
        end
        writeCFrame(hrp, writePos)
        pcall(function()
            hrp.AssemblyLinearVelocity  = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
        end)

    elseif mode == "Momentum Carry" then
        writeCFrame(hrp, writePos)
        if CFG.Bypass.Momentum then
            applyMomentum(hrp, targetPos, dt)
        else
            pcall(function() hrp.AssemblyLinearVelocity = Vector3.zero end)
        end

    else -- Extreme Networking
        writeCFrame(hrp, writePos)
        pcall(function()
            hrp.AssemblyLinearVelocity  = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
        end)
        maybePulse(hrp)
        maybeAntiCorrect(hrp, targetPos)
    end

    VoidState.LastPos = hrp.Position
end

-- ═══════════════════════════════════════════
-- GROUND Y SCAN
-- ═══════════════════════════════════════════
local function updateGroundY()
    local rp = RaycastParams.new()
    rp.FilterType = Enum.RaycastFilterType.Exclude
    if LP.Character then rp.FilterDescendantsInstances = {LP.Character} end
    local result = workspace:Raycast(Vector3.new(0,1000,0), Vector3.new(0,-2000,0), rp)
    if result then VoidState.GroundY = result.Position.Y + 3 end
end

-- ═══════════════════════════════════════════
-- DESYNC SPOOF POSITION
-- ═══════════════════════════════════════════
local function stepSpoofPosition(dt)
    VoidState.GroundUpdateT = VoidState.GroundUpdateT + dt
    if VoidState.GroundUpdateT > 5 then
        VoidState.GroundUpdateT = 0
        task.spawn(updateGroundY)
    end
    local nv = math.noise(VoidState.Elapsed * 0.8, 42.0)
    VoidState.SpoofAngle = VoidState.SpoofAngle
        + VoidState.SpoofDir * (1.5 + nv * CFG.Desync.WanderChaos) * CFG.Desync.WanderSpeed * dt
    if math.noise(VoidState.Elapsed * 0.3, 7.7) > 0.6 then
        VoidState.SpoofDir = -VoidState.SpoofDir
    end
    local r = CFG.Desync.Radius * (0.5 + 0.5 * math.abs(math.noise(VoidState.Elapsed * 0.5, 0)))
    VoidState.FakeGroundPos = Vector3.new(
        VoidState.SpoofBaseX + math.cos(VoidState.SpoofAngle) * r,
        VoidState.GroundY,
        VoidState.SpoofBaseZ + math.sin(VoidState.SpoofAngle) * r
    )
    if CFG.Desync.BaitMode then
        local best, bd = nil, math.huge
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LP and p.Character then
                local eh = p.Character:FindFirstChild("HumanoidRootPart")
                if eh then
                    local d = (eh.Position - VoidState.FakeGroundPos).Magnitude
                    if d < bd then bd = d; best = eh end
                end
            end
        end
        if best then
            local toEnemy = best.Position - VoidState.FakeGroundPos
            if toEnemy.Magnitude > 0 then
                VoidState.FakeGroundPos = VoidState.FakeGroundPos + toEnemy.Unit * CFG.Desync.BaitOffset
            end
        end
    end
end

-- ═══════════════════════════════════════════
-- DESYNC FLICKER
-- ═══════════════════════════════════════════
local function runDesyncFlicker()
    if VoidState.InFlicker then return end
    local hrp = getHRP(); if not hrp then return end
    VoidState.InFlicker = true
    local savedPos = VoidState.IntendedPos

    local function doFlicker()
        local h = getHRP(); if not h then return end
        pcall(function()
            h.CFrame = CFrame.new(VoidState.FakeGroundPos)
            h.AssemblyLinearVelocity = Vector3.new(0, -0.01, 0)
        end)
        task.delay(0, function()
            local h2 = getHRP()
            if h2 and CFG.Void.On then
                pcall(function()
                    h2.CFrame = CFrame.new(savedPos)
                    h2.AssemblyLinearVelocity = Vector3.zero
                end)
            end
        end)
    end

    doFlicker()
    if CFG.Desync.TripleFlicker then
        task.delay(0.008, doFlicker)
        task.delay(0.016, doFlicker)
    end
    task.delay(0.02, function() VoidState.InFlicker = false end)
end

-- ═══════════════════════════════════════════
-- PROJECTILE DETECTION
-- ═══════════════════════════════════════════
local function detectProjectiles()
    if not CFG.Evade.ProjDetect then return false end
    local myPos  = VoidState.IntendedPos
    local params = OverlapParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    if LP.Character then params.FilterDescendantsInstances = {LP.Character} end
    local ok, parts = pcall(function()
        return workspace:GetPartBoundsInRadius(myPos, CFG.Evade.ProjRange, params)
    end)
    if not ok or not parts then return false end
    for _, part in ipairs(parts) do
        if not part:IsDescendantOf(LP.Character or {}) then
            local vel = part.AssemblyLinearVelocity
            if vel.Magnitude > CFG.Evade.ProjSpeed then
                local toUs = myPos - part.Position
                if toUs.Magnitude > 1 and toUs.Unit:Dot(vel.Unit) > 0.35 then
                    CFG.Stats.ProjectilesEvaded = CFG.Stats.ProjectilesEvaded + 1
                    return true
                end
            end
        end
    end
    return false
end

-- ═══════════════════════════════════════════
-- VOID EVASION
-- ═══════════════════════════════════════════
local function checkVoidEvasion()
    if not CFG.Evade.On or VoidState.EvadeCooldown > 0 then return end
    if detectProjectiles() then
        VoidState.X           = VoidState.X + randSign() * CFG.Evade.Speed * 0.5
        VoidState.Z           = VoidState.Z + randSign() * CFG.Evade.Speed * 0.5
        VoidState.YOffset     = VoidState.YOffset + randSign() * CFG.Evade.Vertical
        VoidState.EvadeCooldown = CFG.Evade.Cooldown * 0.5
        return
    end
    local minDist, threatVec = math.huge, Vector3.zero
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and p.Character then
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if hrp and hum and hum.Health > 0 then
                local vel  = hrp.AssemblyLinearVelocity
                local pred = hrp.Position + vel * 0.5
                local d    = (pred - VoidState.IntendedPos).Magnitude
                if d < minDist then
                    minDist   = d
                    threatVec = (pred - VoidState.IntendedPos).Unit
                end
            end
        end
    end
    if minDist < CFG.Evade.Radius then
        local esc    = -threatVec
        local threat = clamp(1 - (minDist / CFG.Evade.Radius), 0, 1)
        VoidState.X   = VoidState.X + esc.X * CFG.Evade.Speed * (1 + threat * 2)
        VoidState.Z   = VoidState.Z + esc.Z * CFG.Evade.Speed * (1 + threat * 2)
        if math.random() < (CFG.Evade.VertBias + threat * 0.2) then
            local vDir = CFG.Evade.ForceUp and 1 or randSign()
            VoidState.YOffset = VoidState.YOffset + vDir * CFG.Evade.Vertical
        end
        VoidState.EvadeCooldown = CFG.Evade.Cooldown * (1 - threat * 0.3)
        if CFG.Void.Method == "Seizure" then refreshSeizurePool() end
    end
end

-- ═══════════════════════════════════════════
-- LOCK TO VOID — main per-frame logic
-- ═══════════════════════════════════════════
local function lockToVoid(dt)
    if VoidState.InFlicker then return end
    if VoidState.EvadeCooldown > 0 then
        VoidState.EvadeCooldown = VoidState.EvadeCooldown - dt
    end
    checkVoidEvasion()
    VoidState.IntendedPos = computeVoidPosition(dt)
    CFG.Stats.CycleCount  = CFG.Stats.CycleCount + 1
    local hrp = getHRP(); if not hrp then return end
    applyBypass(hrp, VoidState.IntendedPos, dt)
    if CFG.Desync.On then
        stepSpoofPosition(dt)
        VoidState.DesyncTimer = VoidState.DesyncTimer + dt
        if VoidState.DesyncTimer >= CFG.Desync.Tick then
            VoidState.DesyncTimer = 0
            task.spawn(runDesyncFlicker)
        end
    end
end

-- ═══════════════════════════════════════════
-- START / STOP VOID
-- ═══════════════════════════════════════════
local function startVoid()
    if VoidState.Conn then VoidState.Conn:Disconnect(); VoidState.Conn = nil end
    task.spawn(function()
        local hrp = getHRP()
        if hrp then pcall(function() hrp:SetNetworkOwner(LP) end) end
        task.spawn(updateGroundY)
    end)
    local hrp = getHRP()
    if hrp then
        local pos = hrp.Position
        VoidState.X              = pos.X
        VoidState.Z              = pos.Z
        VoidState.IntendedPos    = Vector3.new(pos.X, CFG.Void.YBase, pos.Z)
        VoidState.SpoofBaseX     = pos.X
        VoidState.SpoofBaseZ     = pos.Z
        VoidState.LastPos        = pos
        VoidState.LastWrittenPos = pos
    end
    refreshSeizurePool()
    initEchoHistory()
    VoidState.Active = true
    VoidState.Conn   = RunService.Heartbeat:Connect(function(dt)
        if not CFG.Void.On then
            VoidState.Conn:Disconnect()
            VoidState.Conn   = nil
            VoidState.Active = false
            return
        end
        VoidState.Elapsed = VoidState.Elapsed + dt
        lockToVoid(dt)
    end)
end

local function stopVoid()
    if VoidState.Conn then VoidState.Conn:Disconnect(); VoidState.Conn = nil end
    VoidState.Active = false
    local hrp = getHRP()
    if hrp then
        pcall(function()
            hrp.CFrame = CFrame.new(VoidState.SpoofBaseX, VoidState.GroundY + 5, VoidState.SpoofBaseZ)
            hrp.AssemblyLinearVelocity = Vector3.zero
        end)
    end
end

