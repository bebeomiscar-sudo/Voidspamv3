-- safe library loader
-- loadstring returning nil crashes the whole script with "attempt to call nil"
-- this retries up to 3 times and gives a real error message if it fails

local repo = "https://raw.githubusercontent.com/mstudio45/LinoriaLib/main/"

local function safeLoad(url, label)
    local result  = nil
    local lastErr = "unknown"
    local attempt = 0

    while attempt < 3 and not result do
        attempt += 1

        local httpOk, httpResult = pcall(game.HttpGet, game, url)

        if not httpOk or not httpResult or httpResult == "" then
            lastErr = not httpOk and ("HttpGet failed: " .. tostring(httpResult)) or "empty response"
            warn("[RivalsTool] " .. label .. " attempt " .. attempt .. " failed — " .. lastErr)
            task.wait(2)
        else
            local compileOk, compiled = pcall(loadstring, httpResult)

            if not compileOk or type(compiled) ~= "function" then
                lastErr = "loadstring failed: " .. tostring(compiled)
                warn("[RivalsTool] " .. label .. " attempt " .. attempt .. " failed — " .. lastErr)
                task.wait(2)
            else
                local runOk, runResult = pcall(compiled)

                if not runOk then
                    lastErr = "execution failed: " .. tostring(runResult)
                    warn("[RivalsTool] " .. label .. " attempt " .. attempt .. " failed — " .. lastErr)
                    task.wait(2)
                else
                    result = runResult or true
                end
            end
        end
    end

    if not result then
        error("[RivalsTool] Could not load " .. label .. " after 3 attempts. Last error: " .. lastErr)
    end

    return result
end

