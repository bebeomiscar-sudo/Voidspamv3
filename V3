local PART_PRESETS = {
    ["Head"]         = { "Head" },
    ["HumanoidRootPart"] = { "HumanoidRootPart" },
    ["Torso"]        = { "Torso", "UpperTorso", "LowerTorso", "HumanoidRootPart" },
    ["UpperTorso"]   = { "UpperTorso", "Torso", "LowerTorso", "HumanoidRootPart" },
