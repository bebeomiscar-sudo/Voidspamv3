-- TRACER EFFECTS
-- ═══════════════════════════════════════════
local function playTracer(fromPos, toPos, color, width, duration)
    if not TracerEffectModule then return end
    pcall(function()
        TracerEffectModule:Play(fromPos, toPos, color or Config.TracerEffect.Color, width or Config.TracerEffect.Width, duration or Config.TracerEffect.Duration)
    end)
end

local function startTracerShootHook()
    for _, conn in ipairs(tracerConnections) do pcall(function() conn:Disconnect() end) end
    tracerConnections = {}
    local char = LocalPlayer.Character
    if not char then return end

    local function hookTool(tool)
        local conn = tool.Activated:Connect(function()
            if not Config.TracerEffect.Enabled then return end
            if not Config.TracerEffect.OnShoot then return end
            pcall(function()
                local myRoot = char:FindFirstChild("HumanoidRootPart")
                if not myRoot then return end
                local toPos
                if Config.TracerEffect.TraceToEnemy then
                    local enemy = GetClosestEnemy()
                    if enemy and enemy.Character then
                        local eRoot = enemy.Character:FindFirstChild("HumanoidRootPart")
                        if eRoot then toPos = eRoot.Position end
                    end
                else
                    local cam = Workspace.CurrentCamera
                    toPos = cam.CFrame.Position + cam.CFrame.LookVector * 200
                end
                if toPos then playTracer(myRoot.Position, toPos) end
            end)
        end)
        table.insert(tracerConnections, conn)
    end

    for _, child in ipairs(char:GetChildren()) do
        if child:IsA("Tool") then hookTool(child) end
    end
    local conn = char.ChildAdded:Connect(function(child)
        if child:IsA("Tool") then hookTool(child) end
    end)
    table.insert(tracerConnections, conn)
end

local function stopTracers()
    for _, conn in ipairs(tracerConnections) do pcall(function() conn:Disconnect() end) end
    tracerConnections = {}
end

local function drawManualTracer()
    local myChar = LocalPlayer.Character
    if not myChar then return end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end
    local enemy = GetClosestEnemy()
    if not enemy or not enemy.Character then Library:Notify("No enemy found for tracer", 2); return end
    local eRoot = enemy.Character:FindFirstChild("HumanoidRootPart")
    if not eRoot then return end
    playTracer(myRoot.Position, eRoot.Position)
    Library:Notify("Tracer drawn to " .. enemy.Name, 2)
end

