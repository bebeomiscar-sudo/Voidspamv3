-- ═══════════════════════════════════════════
-- PULSE DESYNC (NEW)
-- Alternates between void position (hide phase)
-- and real position (attack phase) on a timer
-- Best used with Projectile TP — hide from server
-- then fire during attack window
-- ═══════════════════════════════════════════
local function startPulseDesync()
    if pulseTask then task.cancel(pulseTask); pulseTask = nil end

    pulseTask = task.spawn(function()
        while Config.PulseDesync.Enabled do
            local char = LocalPlayer.Character
            if char then
                local root = char:FindFirstChild("HumanoidRootPart")
                if root then
                    pulseHrp    = root
                    pulseRealCF = root.CFrame
                    pulseRealV  = root.AssemblyLinearVelocity
                    pulseRealVA = root.AssemblyAngularVelocity

                    -- HIDE PHASE: send to void altitude
                    pulsePhase = "hide"
                    root.CFrame = CFrame.new(
                        pulseRealCF.Position.X + math.random(-50, 50),
                        Config.PulseDesync.VoidAltitude,
                        pulseRealCF.Position.Z + math.random(-50, 50)
                    )
                    root.AssemblyLinearVelocity  = Vector3.new(0, 0, 0)
                    root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)

                    task.wait(Config.PulseDesync.HideTime)

                    -- ATTACK PHASE: restore real position (shoot window)
                    pulsePhase = "attack"
                    if pulseHrp and pulseHrp.Parent then
                        pcall(function()
                            pulseHrp.CFrame                  = pulseRealCF
                            pulseHrp.AssemblyLinearVelocity  = pulseRealV
                            pulseHrp.AssemblyAngularVelocity = pulseRealVA
                        end)
                    end

                    task.wait(Config.PulseDesync.AttackTime)
                end
            end

            if not Config.PulseDesync.Enabled then break end
        end
        pulseTask = nil
        pulsePhase = "attack"
    end)
end

local function stopPulseDesync()
    Config.PulseDesync.Enabled = false
    if pulseTask then task.cancel(pulseTask); pulseTask = nil end
    -- Restore position
    if pulseHrp and pulseRealCF and pulseHrp.Parent then
        pcall(function()
            pulseHrp.CFrame                  = pulseRealCF
            pulseHrp.AssemblyLinearVelocity  = pulseRealV or Vector3.new(0,0,0)
            pulseHrp.AssemblyAngularVelocity = pulseRealVA or Vector3.new(0,0,0)
        end)
    end
    pulsePhase = "attack"
    pulseHrp   = nil
end

