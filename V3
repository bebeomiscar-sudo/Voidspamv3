-- WEAPON TRACKER
-- ═══════════════════════════════════════════
local WT_START_NAMES = {"StartShooting","Shooting"}
local WT_STOP_NAMES  = {"StopShooting","Reload","StartReloading"}

local function wtIsEnemy(player)
    if player == LocalPlayer then return false end
    if Config.WeaponTracker.TeamCheck and isSameTeam(player) then return false end
    return IsAlive(player)
end

local function wtOnEnemyShootStart(shooter)
    if not Config.WeaponTracker.Enabled or not wtIsEnemy(shooter) then return end
    wtShootingPlayers[shooter] = true; wtEnemyShooting = true; wtLastShooter = shooter; wtVoidActive = true
    if wtTeleportTask then task.cancel(wtTeleportTask); wtTeleportTask = nil end
end

local function wtOnEnemyShootStop(shooter)
    if not Config.WeaponTracker.Enabled then return end
    wtShootingPlayers[shooter] = nil
    local any = false; for _ in pairs(wtShootingPlayers) do any = true; break end
    if not any then
        wtEnemyShooting = false; wtVoidActive = false
        local sr = shooter
        wtTeleportTask = task.delay(Config.WeaponTracker.TeleportDelay, function()
            if not Config.WeaponTracker.Enabled or not IsAlive(sr) then return end
            local er = sr.Character and sr.Character:FindFirstChild("HumanoidRootPart")
            local mr = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if er and mr then pcall(function() mr.CFrame = er.CFrame end) end
            wtTeleportTask = nil
        end)
    end
end

local function startWeaponTrackerHook()
    if wtHookActive then return end
    local ok = pcall(function()
        local UseItemRemote = ReplicatedStorage.Remotes.Replication.Fighter.UseItem
        local conn = UseItemRemote.OnClientEvent:Connect(function(fighterOrPlayer, enumAction)
            if not Config.WeaponTracker.Enabled then return end
            local shooter = nil
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer then
                    local char = p.Character
                    if char then
                        local ok2, result = pcall(function()
                            if typeof(fighterOrPlayer) == "Instance" then return fighterOrPlayer:IsDescendantOf(char) end
                            return fighterOrPlayer == p
                        end)
                        if ok2 and result then shooter = p; break end
                    end
                end
            end
            if not shooter then shooter = GetClosestEnemy() end
            if not shooter then return end
            local actionStr = tostring(enumAction)
            local isStart, isStop = false, false
            for _, name in ipairs(WT_START_NAMES) do if string.find(actionStr, name, 1, true) then isStart = true; break end end
            if not isStart then for _, name in ipairs(WT_STOP_NAMES) do if string.find(actionStr, name, 1, true) then isStop = true; break end end end
            if isStart then wtOnEnemyShootStart(shooter) elseif isStop then wtOnEnemyShootStop(shooter) end
        end)
        table.insert(antiOOBConnections, conn); wtHookActive = true
    end)
    if not ok then Library:Notify("Weapon Tracker: hook failed", 3) end
end

local function stopWeaponTrackerHook()
    wtHookActive = false; wtEnemyShooting = false; wtVoidActive = false; wtShootingPlayers = {}
    if wtTeleportTask then task.cancel(wtTeleportTask); wtTeleportTask = nil end
end

