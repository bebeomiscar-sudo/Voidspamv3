local VoidMethods = {}

VoidMethods["Extreme Desync"] = function()
    local intensity = Config.VoidSpam.Intensity / 100
    local range     = math.floor(2147483646 * intensity)
    local dead      = math.floor(1147483646 * intensity)

    hrp.CFrame = CFrame.new(
        randomExclude(-range, range, -dead, dead),
        randomExclude(-range, range, -dead, dead),
        randomExclude(-range, range, -dead, dead)
    ) * CFrame.Angles(math.pi, math.pi, math.pi)

    hrp.AssemblyLinearVelocity = Vector3.new(
        randomExclude(-range, range, -dead, dead),
        randomExclude(-range, range, -dead, dead),
        randomExclude(-range, range, -dead, dead)
    )
    hrp.AssemblyAngularVelocity = Vector3.new(
        randomExclude(-range, range, -dead, dead),
        randomExclude(-range, range, -dead, dead),
        randomExclude(-range, range, -dead, dead)
    )
end

VoidMethods["Projectile TP"] = function()
    local pos = clientCFrame.Position
    hrp.CFrame = CFrame.new(pos.X + math.random(-100, 100), Config.VoidSpam.Altitude, pos.Z + math.random(-100, 100))
    hrp.AssemblyLinearVelocity  = Vector3.zero
    hrp.AssemblyAngularVelocity = Vector3.zero
end

