-- UTILITY
-- ═══════════════════════════════════════════
local function betterRandom(min, max, deadMin, deadMax)
    local val = math.random(min, max)
    repeat val = math.random(min, max)
    until val < deadMin or val > deadMax
    return val
end

local function IsAlive(player)
    if not player or not player.Character then return false end
    local hum = player.Character:FindFirstChildOfClass("Humanoid")
    return hum and hum.Health > 0
end

local function isSameTeam(player)
    local ok1, myTeam    = pcall(function() return LocalPlayer:GetAttribute("TeamID") end)
    local ok2, theirTeam = pcall(function() return player:GetAttribute("TeamID") end)
    if ok1 and ok2 and myTeam ~= nil and theirTeam ~= nil then return myTeam == theirTeam end
    return LocalPlayer.Team ~= nil and player.Team ~= nil and LocalPlayer.Team == player.Team
end

local function isVisibleFrom(origin, targetPart)
    if not targetPart then return false end
    local ok, r = pcall(function()
        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Exclude
        params.FilterDescendantsInstances = {LocalPlayer.Character, targetPart.Parent}
        local hit = Workspace:Raycast(origin, targetPart.Position - origin, params)
        return hit == nil or hit.Instance:IsDescendantOf(targetPart.Parent)
    end)
    return ok and r or false
end

local function GetClosestEnemy()
    local closest, closestDist = nil, math.huge
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and IsAlive(player) then
            if Config.ProjectileTP.TeamCheck and isSameTeam(player) then continue end
            local root   = player.Character:FindFirstChild("HumanoidRootPart")
            local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if root and myRoot then
                local dist = (myRoot.Position - root.Position).Magnitude
                if dist < closestDist and dist <= Config.ProjectileTP.MaxDistance then
                    if Config.ProjectileTP.VisCheck then
                        if not isVisibleFrom(myRoot.Position, root) then continue end
                    end
                    closest     = player
                    closestDist = dist
                end
            end
        end
    end
    return closest
end

local function GetEnemiesSorted()
    local list = {}
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and IsAlive(player) then
            if Config.ProjectileTP.TeamCheck and isSameTeam(player) then continue end
            local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if root and myRoot then
                local dist = (myRoot.Position - root.Position).Magnitude
                if dist <= Config.ProjectileTP.MaxDistance then
                    if Config.ProjectileTP.VisCheck then
                        if not isVisibleFrom(myRoot.Position, root) then continue end
                    end
                    table.insert(list, {player = player, dist = dist})
                end
            end
        end
    end

    local priority = Config.ProjectileTP.Priority
    if priority == "Closest" then
        table.sort(list, function(a, b) return a.dist < b.dist end)
    elseif priority == "Furthest" then
        table.sort(list, function(a, b) return a.dist > b.dist end)
    elseif priority == "Random" then
        for i = #list, 2, -1 do
            local j = math.random(i)
            list[i], list[j] = list[j], list[i]
        end
    elseif priority == "Lowest HP" then
        table.sort(list, function(a, b)
            local ha = a.player.Character:FindFirstChildOfClass("Humanoid")
            local hb = b.player.Character:FindFirstChildOfClass("Humanoid")
            return (ha and ha.Health or 0) < (hb and hb.Health or 0)
        end)
    elseif priority == "Highest HP" then
        table.sort(list, function(a, b)
            local ha = a.player.Character:FindFirstChildOfClass("Humanoid")
            local hb = b.player.Character:FindFirstChildOfClass("Humanoid")
            return (ha and ha.Health or 0) > (hb and hb.Health or 0)
        end)
    end

    local result = {}
    for _, entry in ipairs(list) do table.insert(result, entry.player) end
    return result
end

local function CacheEnemies()
    EnemyCache = GetEnemiesSorted()
end

