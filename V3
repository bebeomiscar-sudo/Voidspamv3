local function playSoundOnce(soundId, volume)
    pcall(function()
        local part = Instance.new("Part")
        part.Anchored = true; part.CanCollide = false; part.Transparency = 1; part.Size = Vector3.one
        local char = lp.Character
        if char then local root = char:FindFirstChild("HumanoidRootPart"); part.Position = root and root.Position or Vector3.zero end
        part.Parent = Workspace
        local snd = Instance.new("Sound")
        snd.SoundId = soundId; snd.Volume = volume or 1; snd.RollOffMaxDistance = 10000; snd.Parent = part; snd:Play()
        task.delay(5, function() pcall(function() part:Destroy() end) end)
    end)
end

local function startSoundSpam()
    if soundSpamTask then task.cancel(soundSpamTask) end
    soundSpamTask = task.spawn(function()
        while Config.SoundSpam.Enabled do
            local id = Config.SoundSpam.CustomId ~= "" and Config.SoundSpam.CustomId or Config.SoundSpam.SoundId
            playSoundOnce(id, Config.SoundSpam.Volume)
            task.wait(math.max(0.01, Config.SoundSpam.Interval))
        end
        soundSpamTask = nil
    end)
end

local function stopSoundSpam()
    Config.SoundSpam.Enabled = false
    if soundSpamTask then task.cancel(soundSpamTask); soundSpamTask = nil end
end

