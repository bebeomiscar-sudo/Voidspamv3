-- ═══════════════════════════════════════════
-- PROJECTILE TP SYSTEM (IMPROVED)
-- Now respects Priority, TeamCheck, VisCheck,
-- MaxDistance, HitboxSize, ShootAttempts
-- Only fires during "attack" phase if PulseDesync active
-- ═══════════════════════════════════════════
local function FindCoreProjectile()
    for _, obj in ipairs(Workspace:GetChildren()) do
        if obj.Name == "CoreProjectile" and obj:FindFirstChild("TouchInterest") then
            return obj
        end
    end
    return nil
end

local function GetEnemyHitbox(enemy)
    if not enemy or not enemy.Character then return nil end
    local targetPart = Config.ProjectileTP.TargetPart
    return enemy.Character:FindFirstChild(targetPart)
        or enemy.Character:FindFirstChild("HitBoxHead")
        or enemy.Character:FindFirstChild("HitBoxHeadSmall")
        or enemy.Character:FindFirstChild("Head")
end

-- Creates a temporary expanded hitbox part near the enemy for easier hit detection
local function createExpandedHitbox(enemy)
    if not enemy or not enemy.Character then return nil end
    local root = enemy.Character:FindFirstChild("HumanoidRootPart")
    if not root then return nil end

    local size = Config.ProjectileTP.HitboxSize
    local hitbox = Instance.new("Part")
    hitbox.Name         = "_ExpandedHitbox"
    hitbox.Size         = Vector3.new(size, size, size)
    hitbox.CFrame       = root.CFrame
    hitbox.Anchored     = true
    hitbox.CanCollide   = false
    hitbox.Transparency = 1
    hitbox.Parent       = Workspace

    -- Auto destroy after 1 second
    task.delay(1, function()
        pcall(function() hitbox:Destroy() end)
    end)

    return hitbox
end

Connections.ProjectileTP = RunService.Heartbeat:Connect(function()
    if not Config.ProjectileTP.Enabled then return end

    -- If Pulse Desync is running, only fire during attack phase
    if Config.PulseDesync.Enabled and pulsePhase ~= "attack" then return end

    -- If Ragebot hide/attack sync is running, only fire during attack phase
    if Config.Ragebot.Enabled and Config.Ragebot.VoidSpamSync and ragebotPhase ~= "attack" then return end

    pcall(function()
        local projectile = FindCoreProjectile()
        if not projectile then return end

        if Config.ProjectileTP.Cache and not ProjectileCache[projectile] then
            ProjectileCache[projectile] = true
        end

        CacheEnemies()

        for _, enemy in ipairs(EnemyCache) do
            local hitbox = GetEnemyHitbox(enemy)
            if not hitbox then continue end

            -- Shoot attempts (from image: shoot attempts slider)
            for attempt = 1, math.max(1, Config.ProjectileTP.ShootAttempts) do
                firetouchinterest(projectile, hitbox, 0)
                task.wait(Config.ProjectileTP.LoopDelay)
                firetouchinterest(projectile, hitbox, 1)

                -- Also try with expanded hitbox if size > default
                if Config.ProjectileTP.HitboxSize > 5 then
                    local expanded = createExpandedHitbox(enemy)
                    if expanded then
                        firetouchinterest(projectile, expanded, 0)
                        task.wait(0.01)
                        firetouchinterest(projectile, expanded, 1)
                    end
                end
            end
        end
    end)
end)

